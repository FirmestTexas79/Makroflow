<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.Makroflow" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/brand_dark</item>
        <item name="colorOnSecondary">@color/brand_cream</item>
        <!-- Kremové pozadí — žádný černý záblesk při startu -->
        <item name="android:windowBackground">@color/brand_cream</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/brand_dark</item>
        <item name="colorTertiary">@color/brand_accent_warm</item>
        <item name="colorOnTertiary">@color/brand_dark</item>
    </style>

    <style name="Theme.Makroflow" parent="Base.Theme.Makroflow">
        <!-- Status bar řízen programově v MainActivity.hideStatusBar() -->
        <!-- windowTranslucentStatus=false aby hideStatusBar() fungoval správně -->
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@color/brand_cream</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="PillShape">
        <item name="cornerSize">25dp</item>
    </style>

    <style name="MacroflowCalendarTheme" parent="Theme.Material3.DayNight">
        <item name="colorPrimary">@color/brand_accent_deep</item>
        <item name="colorOnSurface">@color/brand_dark</item>
        <item name="colorOnSurfaceVariant">@color/brand_primary</item>
    </style>

</resources>