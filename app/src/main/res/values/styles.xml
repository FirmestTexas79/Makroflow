<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="DrawerItemText" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/brand_dark</item>
    </style>

    <style name="BottomNavText" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
    </style>

    <style name="BottomNavText.Active" parent="BottomNavText">
    </style>

    <style name="BottomNavText.Inactive" parent="BottomNavText">
    </style>

    <style name="CustomAlertDialog" parent="Theme.MaterialComponents.Light.Dialog.Alert">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="materialAlertDialogTheme">@style/CustomAlertDialogContent</item>
    </style>

    <style name="CustomAlertDialogContent" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="backgroundTint">@color/brand_cream</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.LargeComponent.Rounded</item>
    </style>

    <style name="ShapeAppearance.LargeComponent.Rounded" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerSize">24dp</item>
    </style>
</resources>