<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/brand_cream"
    android:orientation="vertical"
    android:padding="24dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/metrics_title"
            android:textColor="@color/brand_dark"
            android:textSize="20sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.02" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:background="@drawable/bg_status_pill"
            android:backgroundTint="@color/brand_primary_alpha10"
            android:padding="4dp">

            <ImageButton
                android:id="@+id/btnPrevDay"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_chevron_left"
                app:tint="@color/brand_accent_deep" />

            <TextView
                android:id="@+id/tvSelectedDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:text="@string/metrics_today"
                android:textColor="@color/brand_dark"
                android:textStyle="bold"
                android:textSize="14sp" />

            <ImageButton
                android:id="@+id/btnNextDay"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/brand_accent_deep" />
        </LinearLayout>
    </RelativeLayout>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:alignmentMode="alignMargins">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_gravity="fill_horizontal"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:hint="@string/metrics_hint_neck"
            app:suffixText="@string/metrics_unit_cm"
            app:boxStrokeColor="@color/brand_primary"
            app:hintTextColor="@color/brand_primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNeck"
                android:inputType="numberDecimal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_dark" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_gravity="fill_horizontal"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:hint="@string/metrics_hint_chest"
            app:suffixText="@string/metrics_unit_cm"
            app:boxStrokeColor="@color/brand_primary"
            app:hintTextColor="@color/brand_primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etChest"
                android:inputType="numberDecimal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_dark" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_gravity="fill_horizontal"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:hint="@string/metrics_hint_bicep"
            app:suffixText="@string/metrics_unit_cm"
            app:boxStrokeColor="@color/brand_primary"
            app:hintTextColor="@color/brand_primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBicep"
                android:inputType="numberDecimal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_dark" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_gravity="fill_horizontal"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:hint="@string/metrics_hint_forearm"
            app:suffixText="@string/metrics_unit_cm"
            app:boxStrokeColor="@color/brand_primary"
            app:hintTextColor="@color/brand_primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etForearm"
                android:inputType="numberDecimal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_dark" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_gravity="fill_horizontal"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:hint="@string/metrics_hint_waist"
            app:suffixText="@string/metrics_unit_cm"
            app:boxStrokeColor="@color/brand_primary"
            app:hintTextColor="@color/brand_primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etWaist"
                android:inputType="numberDecimal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_dark" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_gravity="fill_horizontal"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:hint="@string/metrics_hint_abdomen"
            app:suffixText="@string/metrics_unit_cm"
            app:boxStrokeColor="@color/brand_primary"
            app:hintTextColor="@color/brand_primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAbdomen"
                android:inputType="numberDecimal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_dark" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_gravity="fill_horizontal"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:hint="@string/metrics_hint_thigh"
            app:suffixText="@string/metrics_unit_cm"
            app:boxStrokeColor="@color/brand_primary"
            app:hintTextColor="@color/brand_primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etThigh"
                android:inputType="numberDecimal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_dark" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_gravity="fill_horizontal"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:hint="@string/metrics_hint_calf"
            app:suffixText="@string/metrics_unit_cm"
            app:boxStrokeColor="@color/brand_primary"
            app:hintTextColor="@color/brand_primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCalf"
                android:inputType="numberDecimal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_dark" />
        </com.google.android.material.textfield.TextInputLayout>
    </GridLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmMetrics"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="24dp"
        android:text="@string/metrics_btn_save"
        android:textColor="@color/brand_cream"
        android:textStyle="bold"
        app:cornerRadius="16dp"
        app:backgroundTint="@color/brand_dark"
        app:rippleColor="@color/white"/>

</LinearLayout>