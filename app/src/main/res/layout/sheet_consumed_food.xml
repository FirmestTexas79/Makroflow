<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/brand_cream">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_status_pill"
        android:backgroundTint="@color/brand_dark_alpha20" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_pill"
                android:backgroundTint="@color/brand_primary"
                android:paddingHorizontal="14dp"
                android:paddingVertical="5dp"
                android:text="@string/sheet_label_today"
                android:textColor="@color/brand_cream"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.12" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="sans-serif-black"
                android:text="@string/sheet_title_diet"
                android:textColor="@color/brand_dark"
                android:textSize="28sp"
                android:lineSpacingMultiplier="0.9" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvSheetTotalKcal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 kcal"
            android:textColor="@color/brand_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="end" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="20dp"
        android:background="@color/brand_dark_alpha10" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="6dp"
        android:text="@string/sheet_hint_swipe"
        android:textColor="@color/brand_dark_alpha40"
        android:textSize="10sp" />

    <TextView
        android:id="@+id/tvSheetEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="32dp"
        android:gravity="center"
        android:text="@string/sheet_empty_state"
        android:textColor="@color/brand_dark_alpha40"
        android:textSize="14sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/sheetFoodList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="32dp" />

</LinearLayout>