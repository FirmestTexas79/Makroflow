<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_water_dialog"
    android:padding="26dp"
    android:layout_marginHorizontal="20dp"
    android:layout_marginVertical="16dp"
    android:layout_gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-black"
        android:text="Nalejte vodu"
        android:textColor="@color/brand_cream"
        android:textSize="32sp"
        android:lineSpacingMultiplier="0.85" />

    <TextView
        android:id="@+id/tvWaterGoalLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="12dp"
        android:text="Cíl: 4000 ml · Vypito: 4600 ml"
        android:textColor="@color/brand_cream_alpha60"
        android:textSize="13sp" />

    <cz.uhk.macroflow.dashboard.WaterGlassView
        android:id="@+id/waterGlassView"
        android:layout_width="200dp"
        android:layout_height="220dp"
        android:layout_gravity="center"
        android:layout_marginVertical="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn150ml"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="150"
            android:textColor="@color/brand_cream"
            android:textSize="18sp"
            android:fontFamily="sans-serif-black"
            app:strokeColor="@color/brand_cream_alpha40"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn250ml"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:text="250"
            android:textColor="@color/brand_cream"
            android:textSize="18sp"
            android:fontFamily="sans-serif-black"
            app:strokeColor="@color/brand_cream_alpha40"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn500ml"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="500"
            android:textColor="@color/brand_cream"
            android:textSize="18sp"
            android:fontFamily="sans-serif-black"
            app:strokeColor="@color/brand_cream_alpha40"
            app:cornerRadius="16dp" />
    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilWaterAmount"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:hint="Napište přesné množství"
        app:suffixText="ml"
        app:suffixTextColor="@color/brand_cream"
        app:boxStrokeColor="@color/brand_cream_alpha40"
        app:hintTextColor="@color/brand_cream"
        app:boxCornerRadiusTopStart="18dp"
        app:boxCornerRadiusTopEnd="18dp"
        app:boxCornerRadiusBottomStart="18dp"
        app:boxCornerRadiusBottomEnd="18dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etWaterAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:textColor="@color/brand_cream"
            android:textSize="20sp"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:paddingVertical="12dp" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelWater"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="ZRUŠIT"
            android:textColor="@color/brand_cream_alpha60"
            android:fontFamily="sans-serif-black"
            android:textSize="14sp"
            android:layout_marginEnd="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmWater"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:text="VYPÍT"
            android:textColor="@color/brand_dark"
            android:textSize="18sp"
            android:fontFamily="sans-serif-black"
            app:backgroundTint="@color/brand_cream"
            app:cornerRadius="26dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />
    </LinearLayout>
</LinearLayout>