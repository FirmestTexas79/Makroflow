<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_cream"
    android:padding="32dp">

    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:src="@drawable/ic_logo_black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.3"
        app:layout_constraintBottom_toTopOf="@+id/btnGoogleSignIn"/>

    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/app_name_caps"
        android:fontFamily="sans-serif-black"
        android:textSize="32sp"
        android:letterSpacing="0.1"
        android:textColor="@color/brand_dark"
        app:layout_constraintTop_toBottomOf="@id/ivLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvAppTagline"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/app_tagline"
        android:textSize="15sp"
        android:textAlignment="center"
        android:lineSpacingExtra="4dp"
        android:textColor="@color/brand_primary"
        app:layout_constraintTop_toBottomOf="@id/tvAppName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGoogleSignIn"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:layout_marginBottom="16dp"
        android:text="@string/login_google"
        android:textColor="@color/brand_dark"
        android:textStyle="bold"
        app:backgroundTint="@color/white"
        app:strokeColor="@color/brand_primary"
        app:strokeWidth="2dp"
        app:cornerRadius="18dp"
        app:icon="@drawable/ic_barcode_scan"
        app:iconGravity="textStart"
        app:iconTint="@color/brand_dark"
        app:layout_constraintBottom_toTopOf="@id/btnContinueOffline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinueOffline"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:layout_marginBottom="24dp"
        android:text="@string/login_offline"
        android:textColor="@color/brand_cream"
        app:backgroundTint="@color/brand_dark"
        app:cornerRadius="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>