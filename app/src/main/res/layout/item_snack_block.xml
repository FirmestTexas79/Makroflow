<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardSnack"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?android:attr/selectableItemBackground"
    app:cardBackgroundColor="@color/brand_cream"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/brand_dark_alpha10">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvSnackName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/snack_default_name"
                android:textColor="@color/brand_dark"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvSnackWeight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_pill"
                android:backgroundTint="@color/brand_dark_alpha10"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:text="100g"
                android:textColor="@color/brand_primary"
                android:textSize="10sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/valP"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="B: 0g"
                android:textColor="@color/brand_primary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <View
                android:layout_width="1dp"
                android:layout_height="10dp"
                android:layout_marginHorizontal="8dp"
                android:background="@color/brand_dark_alpha20" />

            <TextView
                android:id="@+id/valS"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S: 0g"
                android:textColor="@color/brand_accent_warm"
                android:textSize="11sp"
                android:textStyle="bold" />

            <View
                android:layout_width="1dp"
                android:layout_height="10dp"
                android:layout_marginHorizontal="8dp"
                android:background="@color/brand_dark_alpha20" />

            <TextView
                android:id="@+id/valT"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="T: 0g"
                android:textColor="@color/brand_accent_deep"
                android:textSize="11sp"
                android:textStyle="bold" />

            <View
                android:id="@+id/dividerFiber"
                android:layout_width="1dp"
                android:layout_height="10dp"
                android:layout_marginHorizontal="8dp"
                android:background="@color/brand_dark_alpha20" />

            <TextView
                android:id="@+id/valFiber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="V: 0g"
                android:textColor="@color/brand_dark"
                android:alpha="0.6"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:weightSum="100"
            android:clipChildren="true"
            android:background="@drawable/bg_status_pill"
            android:backgroundTint="@color/brand_dark_alpha05">

            <View
                android:id="@+id/barP"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="10"
                android:background="@drawable/bg_status_pill"
                android:backgroundTint="@color/brand_primary" />

            <View
                android:id="@+id/barS"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="10"
                android:layout_marginStart="2dp"
                android:background="@drawable/bg_status_pill"
                android:backgroundTint="@color/brand_accent_warm" />

            <View
                android:id="@+id/barT"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="10"
                android:layout_marginStart="2dp"
                android:background="@drawable/bg_status_pill"
                android:backgroundTint="@color/brand_accent_deep" />

            <View
                android:id="@+id/barEmpty"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="70" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>