<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/brand_cream"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:fontFamily="sans-serif-black"
        android:text="Přidat do snězených"
        android:textColor="@color/brand_dark"
        android:textSize="22sp"
        android:letterSpacing="0.03"
        android:textAllCaps="true" />

    <!-- Název jídla (read-only) -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Jídlo"
        android:textColorHint="@color/brand_dark_alpha40"
        app:boxStrokeColor="@color/brand_dark_alpha15"
        app:hintTextColor="@color/brand_dark_alpha40"
        app:boxCornerRadiusBottomEnd="16dp"
        app:boxCornerRadiusBottomStart="16dp"
        app:boxCornerRadiusTopEnd="16dp"
        app:boxCornerRadiusTopStart="16dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/tvConsumeName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/brand_dark"
            android:fontFamily="sans-serif-medium"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:cursorVisible="false"
            android:background="@null" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Váha -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilConsumeWeight"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Váha"
        android:textColorHint="@color/brand_dark_alpha40"
        app:suffixText="g"
        app:suffixTextColor="@color/brand_primary"
        app:boxStrokeColor="@color/brand_primary"
        app:hintTextColor="@color/brand_primary"
        app:boxCornerRadiusBottomEnd="16dp"
        app:boxCornerRadiusBottomStart="16dp"
        app:boxCornerRadiusTopEnd="16dp"
        app:boxCornerRadiusTopStart="16dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etConsumeWeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/brand_dark"
            android:inputType="number" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Makra (read-only, live přepočet) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:hint="B"
            app:startIconDrawable="@drawable/ic_dot_protein"
            app:startIconTint="#606C38"
            app:boxStrokeColor="@color/brand_dark_alpha15"
            app:hintTextColor="@color/brand_primary"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomEnd="14dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/tvConsumeP"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_dark"
                android:gravity="center_horizontal"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:cursorVisible="false"
                android:background="@null" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:hint="S"
            app:startIconDrawable="@drawable/ic_dot_carbs"
            app:startIconTint="#DDA15E"
            app:boxStrokeColor="@color/brand_dark_alpha15"
            app:hintTextColor="@color/brand_accent_warm"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomEnd="14dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/tvConsumeS"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_dark"
                android:gravity="center_horizontal"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:cursorVisible="false"
                android:background="@null" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:hint="T"
            app:startIconDrawable="@drawable/ic_dot_fat"
            app:startIconTint="#BC6C25"
            app:boxStrokeColor="@color/brand_dark_alpha15"
            app:hintTextColor="@color/brand_accent_deep"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomEnd="14dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/tvConsumeT"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_dark"
                android:gravity="center_horizontal"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:cursorVisible="false"
                android:background="@null" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <!-- Procenta pod makry -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvConsumePercentP"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:gravity="center"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvConsumePercentS"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:gravity="center"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvConsumePercentT"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Vláknina + kalorie -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp"
        android:text="Doplňkové hodnoty"
        android:textColor="@color/brand_dark_alpha40"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        android:textAllCaps="true" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:hint="Vláknina (v)"
            app:boxStrokeColor="@color/brand_dark_alpha15"
            app:hintTextColor="@color/brand_dark_alpha40"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomEnd="14dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/tvConsumeFiber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_dark"
                android:gravity="center"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:cursorVisible="false"
                android:background="@null" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:hint="Energie"
            app:suffixText="kcal"
            app:suffixTextColor="@color/brand_primary"
            app:boxStrokeColor="@color/brand_dark_alpha15"
            app:hintTextColor="@color/brand_dark_alpha40"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomEnd="14dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/tvConsumeCalories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_dark"
                android:gravity="center"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:cursorVisible="false"
                android:background="@null" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <!-- Procento vlákniny -->
    <TextView
        android:id="@+id/tvConsumePercentFiber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="start"
        android:paddingStart="2dp"
        android:textSize="10sp"
        android:fontFamily="sans-serif-medium"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConsumeConfirm"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="28dp"
        android:text="Přidat do snězených"
        android:textColor="@color/brand_cream"
        android:fontFamily="sans-serif-black"
        app:backgroundTint="@color/brand_dark"
        app:cornerRadius="20dp"
        app:icon="@drawable/ic_save"
        app:iconGravity="textStart" />

</LinearLayout>