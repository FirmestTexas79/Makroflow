<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FEFAE0">

    <ImageView
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-40dp"
        android:layout_marginEnd="-50dp"
        android:src="@drawable/bg_monstera_leaf_1"
        android:alpha="0.07"
        android:rotation="-15"
        app:tint="#283618" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══ HEADER ══ -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                android:paddingTop="56dp"
                android:paddingBottom="8dp">

                <TextView
                    android:id="@+id/tvSettingsBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_status_pill"
                    android:backgroundTint="#606C38"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="KONFIGURACE"
                    android:textColor="#FEFAE0"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvSettingsTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="sans-serif-black"
                    android:text="Nastavení"
                    android:textColor="#283618"
                    android:textSize="42sp"
                    android:lineSpacingMultiplier="0.9"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvSettingsBadge" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Cheaty a editace dat aplikace."
                    android:textColor="#606C38"
                    android:textSize="13sp"
                    android:alpha="0.75"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvSettingsTitle" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ══ ODDĚLOVAČ: DEV CHEATY ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp">
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="#20283618" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp" android:text="🛠 DEV CHEATY"
                    android:textColor="#606C38" android:textSize="10sp" android:textStyle="bold"
                    android:letterSpacing="0.14" />
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="#20283618" />
            </LinearLayout>

            <!-- Cheat karty — 3 vedle sebe -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="20dp"
                android:gravity="center">

                <!-- Poké Ball -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#283618"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="⚪" android:textSize="22sp" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCheatPokeballs"
                            android:layout_width="match_parent"
                            android:layout_height="32dp"
                            android:layout_marginTop="4dp"
                            android:text="+5 Poké Ball"
                            android:textSize="9sp"
                            android:textColor="#FEFAE0"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="#606C38"
                            app:cornerRadius="10dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Great Ball -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="3dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#283618"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🔵" android:textSize="22sp" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCheatGreatballs"
                            android:layout_width="match_parent"
                            android:layout_height="32dp"
                            android:layout_marginTop="4dp"
                            android:text="+5 Great Ball"
                            android:textSize="9sp"
                            android:textColor="#FEFAE0"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="#606C38"
                            app:cornerRadius="10dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Coiny -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#283618"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="💰" android:textSize="22sp" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCheatCoins"
                            android:layout_width="match_parent"
                            android:layout_height="32dp"
                            android:layout_marginTop="4dp"
                            android:text="+100 Coinů"
                            android:textSize="9sp"
                            android:textColor="#FEFAE0"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="#DDA15E"
                            app:cornerRadius="10dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ══ ODDĚLOVAČ: POKÉDEX ══ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp">
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="#20283618" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp" android:text="📖 POKÉDEX EDITOR"
                    android:textColor="#606C38" android:textSize="10sp" android:textStyle="bold"
                    android:letterSpacing="0.14" />
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="#20283618" />
            </LinearLayout>

            <!-- Pokédex edit karta -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#FEFAE0"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#15283618">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EDITOVAT POPIS"
                            android:textColor="#DDA15E"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Upravit typ a popis pokémona"
                            android:textColor="#283618"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-black" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEditPokedex"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:text="Editovat"
                        android:textColor="#FEFAE0"
                        android:textSize="12sp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:backgroundTint="#283618"
                        app:cornerRadius="12dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp">
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="#20283618" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp" android:text="🧪 TESTOVÁNÍ"
                    android:textColor="#606C38" android:textSize="10sp" android:textStyle="bold"
                    android:letterSpacing="0.14" />
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="#20283618" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="40dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#FEFAE0"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#15283618">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PŘIDAT POKÉMONA DO KAPSY"
                        android:textColor="#DDA15E"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Zadej ID z Pokédexu (např. 025)"
                        android:textColor="#283618"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-black" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/etCheatPokemonId"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/bg_status_pill"
                            android:backgroundTint="#15283618"
                            android:hint="Např. 004"
                            android:inputType="number"
                            android:maxLength="3"
                            android:paddingHorizontal="16dp"
                            android:textSize="14sp"
                            android:textColor="#283618" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCheatAddPokemon"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="Získat"
                            android:textColor="#FEFAE0"
                            android:textSize="12sp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="#283618"
                            app:cornerRadius="12dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>