<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_cream">

    <ImageView
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-40dp"
        android:layout_marginEnd="-50dp"
        android:src="@drawable/bg_monstera_leaf_1"
        android:alpha="0.07"
        android:rotation="-15"
        app:tint="@color/brand_dark" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                android:paddingTop="56dp"
                android:paddingBottom="8dp">

                <TextView
                    android:id="@+id/tvSettingsBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_status_pill"
                    android:backgroundTint="@color/brand_primary"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="@string/settings_badge"
                    android:textColor="@color/brand_cream"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvSettingsTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="sans-serif-black"
                    android:text="@string/settings_title"
                    android:textColor="@color/brand_dark"
                    android:textSize="42sp"
                    android:lineSpacingMultiplier="0.9"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvSettingsBadge" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/settings_subtitle"
                    android:textColor="@color/brand_primary"
                    android:textSize="13sp"
                    android:alpha="0.75"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvSettingsTitle" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp">
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="@color/brand_dark_alpha12" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp" android:text="@string/label_dev_cheats"
                    android:textColor="@color/brand_primary" android:textSize="10sp" android:textStyle="bold"
                    android:letterSpacing="0.14" />
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="@color/brand_dark_alpha12" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="20dp"
                android:gravity="center">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="@color/brand_dark"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="⚪" android:textSize="22sp" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCheatPokeballs"
                            android:layout_width="match_parent"
                            android:layout_height="32dp"
                            android:layout_marginTop="4dp"
                            android:text="@string/btn_cheat_poke"
                            android:textSize="9sp"
                            android:textColor="@color/brand_cream"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="@color/brand_primary"
                            app:cornerRadius="10dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="3dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="@color/brand_dark"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🔵" android:textSize="22sp" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCheatGreatballs"
                            android:layout_width="match_parent"
                            android:layout_height="32dp"
                            android:layout_marginTop="4dp"
                            android:text="@string/btn_cheat_great"
                            android:textSize="9sp"
                            android:textColor="@color/brand_cream"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="@color/brand_primary"
                            app:cornerRadius="10dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="@color/brand_dark"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="💰" android:textSize="22sp" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCheatCoins"
                            android:layout_width="match_parent"
                            android:layout_height="32dp"
                            android:layout_marginTop="4dp"
                            android:text="@string/btn_cheat_coins"
                            android:textSize="9sp"
                            android:textColor="@color/brand_cream"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="@color/brand_accent_warm"
                            app:cornerRadius="10dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp">
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="@color/brand_dark_alpha12" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp" android:text="@string/label_pokedex_editor"
                    android:textColor="@color/brand_primary" android:textSize="10sp" android:textStyle="bold"
                    android:letterSpacing="0.14" />
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="@color/brand_dark_alpha12" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="@color/brand_cream"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/brand_dark_alpha12">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_edit_desc_caps"
                            android:textColor="@color/brand_accent_warm_light"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/settings_edit_pokedex_hint"
                            android:textColor="@color/brand_dark"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-black" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEditPokedex"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:text="@string/btn_edit"
                        android:textColor="@color/brand_cream"
                        android:textSize="12sp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:backgroundTint="@color/brand_dark"
                        app:cornerRadius="12dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp">
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="@color/brand_dark_alpha12" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp" android:text="@string/label_testing"
                    android:textColor="@color/brand_primary" android:textSize="10sp" android:textStyle="bold"
                    android:letterSpacing="0.14" />
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="@color/brand_dark_alpha12" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="40dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="@color/brand_cream"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/brand_dark_alpha12">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_add_to_pocket"
                        android:textColor="@color/brand_accent_warm_light"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/settings_id_hint_desc"
                        android:textColor="@color/brand_dark"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-black" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/etCheatPokemonId"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/bg_status_pill"
                            android:backgroundTint="@color/brand_dark_alpha5"
                            android:hint="@string/hint_id_example"
                            android:inputType="number"
                            android:maxLength="3"
                            android:paddingHorizontal="16dp"
                            android:textSize="14sp"
                            android:textColor="@color/brand_dark" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCheatAddPokemon"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="@string/btn_get"
                            android:textColor="@color/brand_cream"
                            android:textSize="12sp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            app:backgroundTint="@color/brand_dark"
                            app:cornerRadius="12dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp">
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="@color/brand_dark_alpha12" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp" android:text="PROMO SYSTÉM"
                    android:textColor="@color/brand_primary" android:textSize="10sp" android:textStyle="bold"
                    android:letterSpacing="0.14" />
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="@color/brand_dark_alpha12" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="@color/brand_cream"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/brand_dark_alpha12">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UPLATNIT KÓD"
                        android:textColor="@color/brand_accent_warm_light"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/etPromoCode"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="12dp"
                            android:background="@drawable/bg_status_pill"
                            android:backgroundTint="@color/brand_dark_alpha5"
                            android:hint="Zadej kód"
                            android:inputType="textCapCharacters"
                            android:paddingHorizontal="16dp"
                            android:textSize="14sp"
                            android:textColor="@color/brand_dark" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnApplyPromo"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="OK"
                            android:textColor="@color/brand_cream"
                            app:backgroundTint="@color/brand_dark"
                            app:cornerRadius="12dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>