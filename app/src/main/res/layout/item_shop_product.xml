<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardShopItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/brand_cream"
    app:cardCornerRadius="20dp"
    app:strokeColor="@color/brand_primary_alpha30"
    app:strokeWidth="1dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:id="@+id/ivProductIcon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_home"
            app:tint="@null" /> <TextView
        android:id="@+id/tvProductName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/brand_dark"
        android:textSize="17sp"
        android:fontFamily="sans-serif-black"
        android:text="@string/shop_item_default_name" />

        <TextView
            android:id="@+id/tvProductDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center"
            android:textColor="@color/brand_primary"
            android:textSize="13sp"
            android:text="@string/shop_item_default_desc" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBuyProduct"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="KOUPIT"
            android:textColor="@color/brand_cream"
            android:fontFamily="sans-serif-black"
            app:backgroundTint="@color/brand_accent_deep"
            app:cornerRadius="12dp"
            app:rippleColor="@color/white" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>