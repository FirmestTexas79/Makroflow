<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_cream">

    <ImageView
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-40dp"
        android:layout_marginEnd="-70dp"
        android:src="@drawable/bg_monstera_leaf_1"
        android:alpha="0.07"
        android:rotation="-30"
        app:tint="@color/brand_dark" />

    <ImageView
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-30dp"
        android:layout_marginBottom="100dp"
        android:src="@drawable/bg_monstera_leaf_2"
        android:alpha="0.08"
        android:rotation="40"
        app:tint="@color/brand_primary" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/snackListsContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="190dp"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                android:paddingTop="56dp"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/tvSnackBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_status_pill"
                    android:backgroundTint="@color/brand_accent_warm"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="MAKRO ŠPAJZKA"
                    android:textColor="@color/brand_cream"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.12"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvSnackTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="sans-serif-black"
                    android:text="Snacky"
                    android:textColor="@color/brand_dark"
                    android:textSize="42sp"
                    android:lineSpacingMultiplier="0.9"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvSnackBadge" />

                <TextView
                    android:id="@+id/tvSnackSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Klikni a přidej do dnešního dne"
                    android:textColor="@color/brand_primary"
                    android:textSize="13sp"
                    android:alpha="0.75"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvSnackTitle" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:padding="4dp"
                android:background="@drawable/bg_search_field"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/ivSearchIcon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginStart="12dp"
                    android:src="@drawable/ic_search" />

                <EditText
                    android:id="@+id/etSnackSearch"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:background="@null"
                    android:hint="Hledej v zásobách..."
                    android:textColor="@color/brand_dark"
                    android:textColorHint="@color/brand_accent_deep"
                    android:paddingHorizontal="12dp"
                    android:textSize="15sp"
                    android:inputType="text"
                    android:maxLines="1" />

                <ImageView
                    android:id="@+id/ivClearSearch"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginEnd="10dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_close"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:visibility="gone" />

            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="28dp"
                app:cardBackgroundColor="@color/brand_dark_alpha5"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggleSnackTiming"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    app:checkedButton="@+id/btnPreWorkout">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPreWorkout"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="150dp"
                        android:layout_height="match_parent"
                        android:text="@string/before_training"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-black"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:cornerRadius="28dp"
                        app:strokeWidth="0dp"
                        android:textColor="@color/brand_dark" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPostWorkout"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="150dp"
                        android:layout_height="match_parent"
                        android:text="@string/after_training"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-black"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:cornerRadius="28dp"
                        app:strokeWidth="0dp"
                        android:textColor="@color/brand_dark" />

                </com.google.android.material.button.MaterialButtonToggleGroup>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/brand_dark_alpha20" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:text="@string/sacharidy"
                    android:textColor="@color/brand_accent_warm"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.12" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/brand_dark_alpha20" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/listCarbs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="8dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/brand_dark_alpha20" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:text="@string/proteiny"
                    android:textColor="@color/brand_primary"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.12" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/brand_dark_alpha20" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/listProteins"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/deleteOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#EEFEFAE0"
        android:gravity="center"
        android:orientation="horizontal"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/btnDeleteAction"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginEnd="48dp"
            android:background="@drawable/bg_status_pill"
            android:backgroundTint="@color/brand_accent_deep_alpha20"
            android:padding="16dp">
            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_delete_confirm"
                app:tint="@color/brand_accent_deep" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="SMAZAT"
                android:textColor="@color/brand_accent_deep"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.08" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnCancelAction"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@drawable/bg_status_pill"
            android:backgroundTint="@color/brand_primary_alpha10"
            android:padding="16dp">
            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_cancel_confirm"
                app:tint="@color/brand_primary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="ZPĚT"
                android:textColor="@color/brand_primary"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.08" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btnOpenTinder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="108dp"
        android:text="Swipe jídlo"
        android:textColor="@color/brand_cream"
        android:textSize="12sp"
        android:fontFamily="sans-serif-black"
        app:icon="@android:drawable/ic_menu_sort_by_size"
        app:iconTint="@color/brand_cream"
        app:backgroundTint="@color/brand_primary"
        app:elevation="6dp"
        app:cornerRadius="28dp" />

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btnOpenMealBuilder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="210dp"
        android:text="Složit jídlo"
        android:textColor="@color/brand_cream"
        android:textSize="12sp"
        android:fontFamily="sans-serif-black"
        app:icon="@android:drawable/ic_menu_edit"
        app:iconTint="@color/brand_cream"
        app:backgroundTint="@color/brand_accent_warm"
        app:elevation="6dp"
        app:cornerRadius="28dp" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnAiScanner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="140dp"
        android:src="@android:drawable/ic_menu_camera"
        app:tint="@color/brand_cream"
        app:backgroundTint="#BC6C25"
        app:elevation="8dp"
        app:fabSize="normal" />

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAddSnack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="108dp"
        android:text="Přidat"
        android:textColor="@color/brand_cream"
        android:textSize="12sp"
        android:fontFamily="sans-serif-black"
        app:icon="@android:drawable/ic_input_add"
        app:iconTint="@color/brand_cream"
        app:backgroundTint="@color/brand_dark"
        app:elevation="6dp"
        app:cornerRadius="28dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>