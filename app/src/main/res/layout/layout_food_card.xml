<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <TextView
        android:id="@+id/tvFoodContextBanner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="32dp"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:elevation="14dp"
        android:background="@drawable/bg_status_pill"
        android:backgroundTint="@color/brand_dark"
        android:textColor="@color/brand_cream"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.02"
        android:translationY="20dp"
        android:visibility="gone" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/foodCard"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:cardCornerRadius="48dp"
        app:cardElevation="20dp"
        app:cardBackgroundColor="@color/brand_cream"
        app:strokeWidth="3dp"
        app:strokeColor="@color/brand_dark_alpha40"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:cardUseCompatPadding="true"
        app:cardPreventCornerOverlap="false">

        <!--
            Plný vertical LinearLayout místo ConstraintLayout.
            ConstraintLayout s GONE views a chybějícími top-chain vazbami
            způsoboval kolaps obsahu (překryv textu) u některých jídel.
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="24dp">

            <!-- Ikonový kruh -->
            <FrameLayout
                android:layout_width="140dp"
                android:layout_height="140dp">

                <View
                    android:id="@+id/viewImageBg"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_status_pill"
                    android:backgroundTint="#08283618" />

                <ImageView
                    android:id="@+id/ivFoodImage"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_macro_carbs"
                    app:tint="@color/brand_primary" />
            </FrameLayout>

            <!-- Název jídla -->
            <TextView
                android:id="@+id/tvFoodName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:text="Proteinová Kaše"
                android:textColor="@color/brand_dark"
                android:textSize="26sp"
                android:lineSpacingExtra="-2sp"
                android:letterSpacing="-0.02"
                android:minLines="1"
                android:maxLines="2"
                android:ellipsize="end" />

            <!--
                Timing tag — když je GONE nepřidává žádnou výšku,
                marginTop se projeví jen když je VISIBLE.
            -->
            <TextView
                android:id="@+id/tvFoodTimingTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:background="@drawable/bg_status_pill"
                android:backgroundTint="#15606C38"
                android:textColor="@color/brand_primary"
                android:visibility="gone" />

            <!-- Kalorie + label -->
            <LinearLayout
                android:id="@+id/llCalContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="16dp">

                <TextView
                    android:id="@+id/tvFoodCalories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:includeFontPadding="false"
                    android:text="452 kcal | 1890 kJ"
                    android:textColor="@color/brand_dark"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/tvCalLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ENERGETICKÁ HODNOTA"
                    android:alpha="0.5"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:textColor="@color/brand_dark" />
            </LinearLayout>

            <!--
                Vláknina — marginTop jen vizuálně odděluje od kalorií,
                GONE nepřidává výšku (LinearLayout to respektuje správně).
            -->
            <TextView
                android:id="@+id/tvFoodFiber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="Vláknina: 5.2g"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/brand_dark"
                android:alpha="0.7"
                android:background="@drawable/bg_status_pill"
                android:backgroundTint="#10283618"
                android:visibility="gone" />

            <!-- Makra — P / S / T -->
            <LinearLayout
                android:id="@+id/macroContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginTop="16dp">

                <!-- Bílkoviny (P) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_status_pill"
                    android:backgroundTint="#08283618"
                    android:paddingVertical="14dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="P"
                        android:textSize="10sp"
                        android:alpha="0.5"
                        android:textStyle="bold"
                        android:textColor="@color/brand_primary" />

                    <TextView
                        android:id="@+id/tvFoodProtein"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="24g"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/brand_primary" />
                </LinearLayout>

                <!-- Sacharidy (S) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_status_pill"
                    android:backgroundTint="#08DDA15E"
                    android:paddingVertical="14dp"
                    android:layout_marginHorizontal="3dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="S"
                        android:textSize="10sp"
                        android:alpha="0.5"
                        android:textStyle="bold"
                        android:textColor="@color/brand_accent_warm" />

                    <TextView
                        android:id="@+id/tvFoodCarbs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="52g"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/brand_accent_warm" />
                </LinearLayout>

                <!-- Tuky (T) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_status_pill"
                    android:backgroundTint="#08BC6C25"
                    android:paddingVertical="14dp"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="T"
                        android:textSize="10sp"
                        android:alpha="0.5"
                        android:textStyle="bold"
                        android:textColor="@color/brand_accent_deep" />

                    <TextView
                        android:id="@+id/tvFoodFat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12g"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/brand_accent_deep" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>
</FrameLayout>