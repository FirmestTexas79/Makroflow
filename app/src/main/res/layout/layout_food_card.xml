<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:gravity="center">

    <!--
        Kontextový banner — zobrazí se automaticky nad kartou
        podle aktuálního času vs. čas tréninku.
        FoodSwipeDialog ho nastaví přes tvFoodContextBanner.
    -->
    <TextView
        android:id="@+id/tvFoodContextBanner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="24dp"
        android:paddingHorizontal="18dp"
        android:paddingVertical="7dp"
        android:text=""
        android:textSize="12sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/bg_status_pill"
        android:backgroundTint="#283618"
        android:textColor="#FEFAE0"
        android:visibility="gone"
        android:elevation="4dp" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/foodCard"
        android:layout_width="300dp"
        android:layout_height="450dp"
        android:layout_gravity="center"
        app:cardCornerRadius="40dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="@color/brand_cream"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:cardPreventCornerOverlap="false"
        app:cardUseCompatPadding="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="24dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <ImageView
                android:id="@+id/ivFoodImage"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:src="@drawable/bg_monstera_leaf_1"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:tint="@color/brand_primary" />

            <TextView
                android:id="@+id/tvFoodName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Název jídla"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/brand_dark"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/ivFoodImage"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!--
                Štítek kontextu uvnitř karty — malý, pod názvem
                Ukazuje např. "PRE trénink" nebo "POST okno"
            -->
            <TextView
                android:id="@+id/tvFoodTimingTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:background="@drawable/bg_status_pill"
                android:backgroundTint="#15606C38"
                android:textColor="#606C38"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/tvFoodName"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tvCalLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ENERGIE"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:textColor="@color/brand_accent_deep"
                app:layout_constraintBottom_toTopOf="@id/tvFoodCalories"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tvFoodCalories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 kcal"
                android:textSize="48sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/brand_dark"
                app:layout_constraintTop_toBottomOf="@id/tvFoodName"
                app:layout_constraintBottom_toTopOf="@id/macroContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <LinearLayout
                android:id="@+id/macroContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:id="@+id/containerProtein"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_macro_protein" />
                    <TextView
                        android:id="@+id/tvFoodProtein"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0g"
                        android:textStyle="bold"
                        android:textColor="@color/brand_primary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/containerCarbs"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_macro_carbs" />
                    <TextView
                        android:id="@+id/tvFoodCarbs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0g"
                        android:textStyle="bold"
                        android:textColor="@color/brand_accent_warm" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/containerFat"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_macro_fat"/>
                    <TextView
                        android:id="@+id/tvFoodFat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0g"
                        android:textStyle="bold"
                        android:textColor="@color/brand_accent_deep" />
                </LinearLayout>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>