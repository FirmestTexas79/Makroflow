<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardDay"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/brand_cream"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeWidth="1.5dp"
    app:strokeColor="#20283618">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="14dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:id="@+id/layoutDayLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="4dp"
            app:layout_constraintHorizontal_weight="0.22"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/toggleGroup"
            app:layout_constraintBottom_toBottomOf="@id/toggleGroup"
            app:layout_constraintEnd_toStartOf="@id/divider">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvDayName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/day_po_short"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.02" />

                <View
                    android:id="@+id/viewAccent"
                    android:layout_width="9dp"
                    android:layout_height="9dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_status_pill"
                    android:backgroundTint="@color/brand_accent_warm"
                    android:visibility="gone" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvDayFull"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/day_monday"
                android:textColor="@color/brand_primary"
                android:textSize="10sp"
                android:alpha="0.7" />

        </LinearLayout>

        <View
            android:id="@+id/divider"
            android:layout_width="1dp"
            android:layout_height="36dp"
            android:background="#20283618"
            app:layout_constraintStart_toEndOf="@id/layoutDayLabel"
            app:layout_constraintEnd_toStartOf="@id/toggleGroup"
            app:layout_constraintTop_toTopOf="@id/toggleGroup"
            app:layout_constraintBottom_toBottomOf="@id/toggleGroup" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            app:selectionRequired="true"
            app:singleSelection="true"
            app:checkedButton="@+id/btnRest"
            app:layout_constraintHorizontal_weight="0.78"
            app:layout_constraintStart_toEndOf="@id/divider"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRest"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="@string/plan_off"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:strokeColor="#20283618"
                app:cornerRadius="12dp"
                android:maxLines="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPush"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="@string/plan_push"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/brand_dark"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:strokeColor="#20283618"
                android:maxLines="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPull"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="@string/plan_pull"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/brand_primary"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:strokeColor="#20283618"
                android:maxLines="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLegs"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="@string/plan_legs"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/brand_accent_deep"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:strokeColor="#20283618"
                android:maxLines="1" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

        <TextView
            android:id="@+id/tvTrainingTimePill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginStart="4dp"
            android:text="@string/plan_set_time"
            android:textColor="@color/brand_primary_light"
            android:textSize="11sp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:background="@drawable/bg_status_pill"
            android:backgroundTint="#1A606C38"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/toggleGroup"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>