<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginHorizontal="16dp"
    app:cardBackgroundColor="@color/brand_cream"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#1A283618">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingVertical="14dp"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvDayName"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:textColor="@color/brand_dark"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:text="Pon." />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:selectionRequired="true"
            app:singleSelection="true"
            app:checkedButton="@+id/btnRest">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRest"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="OFF"
                android:textSize="11sp"
                android:textColor="@color/brand_accent_deep"
                app:rippleColor="#1ABC6C25" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPush"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="PUSH"
                android:textStyle="bold"
                android:textSize="11sp"
                android:textColor="@color/brand_primary"
                app:rippleColor="#1A606C38" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPull"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="PULL"
                android:textStyle="bold"
                android:textSize="11sp"
                android:textColor="@color/brand_dark"
                app:rippleColor="#1A283618" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLegs"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="LEGS"
                android:textStyle="bold"
                android:textSize="11sp"
                android:textColor="@color/brand_dark"
                app:rippleColor="#1A283618" />

        </com.google.android.material.button.MaterialButtonToggleGroup>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>