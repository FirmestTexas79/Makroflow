<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardDay"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="#FEFAE0"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeWidth="1.5dp"
    app:strokeColor="#20283618">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="18dp"
        android:paddingVertical="16dp">

        <!-- Den: zkratka + tečka vedle + celý název pod tím -->
        <LinearLayout
            android:id="@+id/layoutDayLabel"
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Zkratka + tečka vedle sebe, vertikálně centrované -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvDayName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PO"
                    android:textColor="#283618"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="-0.02" />

                <!-- Tečka — zobrazí se jen když je den aktivní -->
                <View
                    android:id="@+id/viewAccent"
                    android:layout_width="9dp"
                    android:layout_height="9dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_status_pill"
                    android:backgroundTint="#DDA15E"
                    android:visibility="gone" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvDayFull"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pondělí"
                android:textColor="#606C38"
                android:textSize="10sp"
                android:alpha="0.7" />

        </LinearLayout>

        <!-- Tenká svislá čára — oddělovač -->
        <View
            android:id="@+id/divider"
            android:layout_width="1dp"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="#20283618"
            app:layout_constraintStart_toEndOf="@id/layoutDayLabel"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Toggle tlačítka -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            app:selectionRequired="true"
            app:singleSelection="true"
            app:checkedButton="@+id/btnRest"
            app:layout_constraintStart_toEndOf="@id/divider"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRest"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="OFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                android:textColor="#BC6C25"
                app:strokeColor="#20BC6C25"
                app:rippleColor="#1ABC6C25"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPush"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="PUSH"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                android:textColor="#606C38"
                app:strokeColor="#20606C38"
                app:rippleColor="#1A606C38"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPull"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="PULL"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                android:textColor="#283618"
                app:strokeColor="#20283618"
                app:rippleColor="#1A283618"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLegs"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="LEGS"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                android:textColor="#283618"
                app:strokeColor="#20283618"
                app:rippleColor="#1A283618"
                app:cornerRadius="12dp" />

        </com.google.android.material.button.MaterialButtonToggleGroup>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>