<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/brand_cream"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:fontFamily="sans-serif-black"
        android:text="NOVÝ SNACK DO DATABÁZE"
        android:textColor="@color/brand_dark"
        android:textSize="20sp"
        android:letterSpacing="0.02" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilSnackName"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Název snacku"
        android:textColorHint="@color/brand_dark"
        app:boxStrokeColor="@color/brand_primary"
        app:hintTextColor="@color/brand_primary"
        app:endIconMode="custom"
        app:endIconDrawable="@drawable/ic_barcode_scan"
        app:endIconTint="@color/brand_primary"
        app:placeholderText="např. Protein bar"
        app:placeholderTextColor="@color/brand_accent_deep">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSnackName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/brand_dark"
            android:inputType="textCapSentences" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilSnackWeight"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Váha balení"
        android:textColorHint="@color/brand_dark"
        app:suffixText="g"
        app:suffixTextColor="@color/brand_dark"
        app:boxStrokeColor="@color/brand_primary"
        app:hintTextColor="@color/brand_primary">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSnackWeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/brand_dark"
            android:inputType="number" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:hint="B"
            android:textColorHint="@color/brand_dark"
            app:startIconDrawable="@drawable/ic_dot_protein"
            app:startIconTint="@color/brand_primary"
            app:boxStrokeColor="@color/brand_primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSnackP"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_dark"
                android:fontFamily="monospace"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="6dp"
            android:hint="S"
            android:textColorHint="@color/brand_dark"
            app:startIconDrawable="@drawable/ic_dot_carbs"
            app:startIconTint="@color/brand_accent_warm"
            app:boxStrokeColor="@color/brand_accent_warm">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSnackS"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_dark"
                android:fontFamily="monospace"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:hint="T"
            android:textColorHint="@color/brand_dark"
            app:startIconDrawable="@drawable/ic_dot_fat"
            app:startIconTint="@color/brand_accent_deep"
            app:boxStrokeColor="@color/brand_accent_deep">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSnackT"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_dark"
                android:fontFamily="monospace"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSwitchContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="@color/brand_cream"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="1.5dp"
        app:strokeColor="@color/brand_accent_warm">

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/cbIsPreWorkout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text="Předtréninkový snack"
            android:textColor="@color/brand_dark"
            android:textStyle="bold"
            app:thumbTint="@color/brand_primary" />

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveSnack"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="32dp"
        android:text="ULOŽIT DO DATABÁZE"
        android:textColor="@color/brand_cream"
        android:textStyle="bold"
        app:backgroundTint="@color/brand_dark"
        app:cornerRadius="16dp"
        app:icon="@drawable/ic_save"
        app:iconGravity="textStart" />

</LinearLayout>