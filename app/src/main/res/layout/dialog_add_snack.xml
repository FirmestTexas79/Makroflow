<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/brand_cream"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:fontFamily="sans-serif-black"
        android:text="@string/snack_dialog_title"
        android:textColor="@color/brand_dark"
        android:textSize="22sp"
        android:letterSpacing="0.03"
        android:textAllCaps="true" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilSnackName"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/snack_hint_name"
        android:textColorHint="@color/brand_dark_alpha40"
        app:boxStrokeColor="@color/brand_primary"
        app:hintTextColor="@color/brand_primary"
        app:endIconMode="custom"
        app:endIconDrawable="@drawable/ic_barcode_scan"
        app:endIconTint="@color/brand_accent_deep"
        app:boxCornerRadiusBottomEnd="16dp"
        app:boxCornerRadiusBottomStart="16dp"
        app:boxCornerRadiusTopEnd="16dp"
        app:boxCornerRadiusTopStart="16dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSnackName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/brand_dark"
            android:fontFamily="sans-serif-medium"
            android:inputType="textCapSentences" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilSnackWeight"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="@string/snack_hint_weight"
        android:textColorHint="@color/brand_dark_alpha40"
        app:suffixText="g"
        app:suffixTextColor="@color/brand_primary"
        app:boxStrokeColor="@color/brand_primary"
        app:hintTextColor="@color/brand_primary"
        app:boxCornerRadiusBottomEnd="16dp"
        app:boxCornerRadiusBottomStart="16dp"
        app:boxCornerRadiusTopEnd="16dp"
        app:boxCornerRadiusTopStart="16dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSnackWeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/brand_dark"
            android:inputType="number" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:hint="B"
            app:startIconDrawable="@drawable/ic_dot_protein"
            app:startIconTint="#606C38"
            app:boxStrokeColor="@color/brand_primary"
            app:hintTextColor="@color/brand_primary"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomEnd="14dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSnackP"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_dark"
                android:gravity="center_horizontal"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:hint="S"
            app:startIconDrawable="@drawable/ic_dot_carbs"
            app:startIconTint="#DDA15E"
            app:boxStrokeColor="@color/brand_accent_warm"
            app:hintTextColor="@color/brand_accent_warm"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomEnd="14dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSnackS"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_dark"
                android:gravity="center_horizontal"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:hint="T"
            app:startIconDrawable="@drawable/ic_dot_fat"
            app:startIconTint="#BC6C25"
            app:boxStrokeColor="@color/brand_accent_deep"
            app:hintTextColor="@color/brand_accent_deep"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomEnd="14dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSnackT"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_dark"
                android:gravity="center_horizontal"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp"
        android:text="Volitelné doplňky"
        android:textColor="@color/brand_dark_alpha40"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        android:textAllCaps="true" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:hint="Vláknina (v)"
            app:boxStrokeColor="@color/brand_dark_alpha15"
            app:hintTextColor="@color/brand_dark_alpha40"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomEnd="14dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSnackFiber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_dark"
                android:gravity="center"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:hint="Cholest. (mg)"
            app:boxStrokeColor="@color/brand_dark_alpha15"
            app:hintTextColor="@color/brand_dark_alpha40"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomEnd="14dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSnackCholesterol"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/brand_dark"
                android:gravity="center"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="@color/brand_cream_alpha40"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/brand_dark_alpha12">

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/cbIsPreWorkout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text="@string/snack_toggle_preworkout"
            android:textColor="@color/brand_dark"
            android:fontFamily="sans-serif-medium"
            app:thumbTint="@color/brand_primary"
            app:trackTint="@color/brand_primary_alpha20" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveSnack"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="28dp"
        android:text="@string/snack_btn_save"
        android:textColor="@color/brand_cream"
        android:fontFamily="sans-serif-black"
        app:backgroundTint="@color/brand_dark"
        app:cornerRadius="20dp"
        app:icon="@drawable/ic_save"
        app:iconGravity="textStart" />

</LinearLayout>