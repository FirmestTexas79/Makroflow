<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_cream">

    <ImageView
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-50dp"
        android:layout_marginEnd="-60dp"
        android:src="@drawable/bg_monstera_leaf_1"
        android:alpha="0.06"
        android:rotation="-15"
        app:tint="@color/brand_dark" />

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-20dp"
        android:layout_marginBottom="120dp"
        android:src="@drawable/bg_monstera_leaf_2"
        android:alpha="0.07"
        android:rotation="60"
        app:tint="@color/brand_primary" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                android:paddingTop="56dp"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/tvHistoryBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_status_pill"
                    android:backgroundTint="@color/brand_primary"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="@string/history_badge"
                    android:textColor="@color/brand_cream"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvHistoryTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="sans-serif-black"
                    android:text="@string/history_title"
                    android:textColor="@color/brand_dark"
                    android:textSize="42sp"
                    android:lineSpacingMultiplier="0.9"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvHistoryBadge" />

                <TextView
                    android:id="@+id/tvHistorySub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/history_subtitle"
                    android:textColor="@color/brand_primary"
                    android:textSize="13sp"
                    android:alpha="0.75"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvHistoryTitle" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@color/brand_dark"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="12dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="4dp">

                        <ImageButton
                            android:id="@+id/btnPrevMonth"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_status_pill"
                            android:backgroundTint="@color/brand_cream_alpha20"
                            android:src="@drawable/ic_chevron_right"
                            android:rotation="180"
                            app:tint="@color/brand_cream"
                            android:scaleType="center" />

                        <TextView
                            android:id="@+id/tvMonthLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/history_month_placeholder"
                            android:textColor="@color/brand_cream"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-black" />

                        <ImageButton
                            android:id="@+id/btnNextMonth"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_status_pill"
                            android:backgroundTint="@color/brand_cream_alpha20"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/brand_cream"
                            android:scaleType="center" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/calDayHeaders"
                        android:layout_width="match_parent"
                        android:layout_height="32dp"
                        android:orientation="horizontal"
                        android:paddingHorizontal="8dp">

                        <TextView android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:gravity="center" android:text="@string/day_mon_short"
                            android:textColor="@color/brand_accent_warm" android:textSize="11sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:gravity="center" android:text="@string/day_tue_short"
                            android:textColor="@color/brand_accent_warm" android:textSize="11sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:gravity="center" android:text="@string/day_wed_short"
                            android:textColor="@color/brand_accent_warm" android:textSize="11sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:gravity="center" android:text="@string/day_thu_short"
                            android:textColor="@color/brand_accent_warm" android:textSize="11sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:gravity="center" android:text="@string/day_fri_short"
                            android:textColor="@color/brand_accent_warm" android:textSize="11sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:gravity="center" android:text="@string/day_sat_short"
                            android:textColor="@color/brand_cream_alpha60" android:textSize="11sp" android:textStyle="bold" />
                        <TextView android:layout_width="0dp" android:layout_height="match_parent"
                            android:layout_weight="1" android:gravity="center" android:text="@string/day_sun_short"
                            android:textColor="@color/brand_cream_alpha60" android:textSize="11sp" android:textStyle="bold" />

                    </LinearLayout>

                    <GridLayout
                        android:id="@+id/calGrid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="7"
                        android:paddingHorizontal="8dp"
                        android:paddingBottom="12dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/brand_dark_alpha12" />

                <TextView
                    android:id="@+id/tvSelectedDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:background="@drawable/bg_status_pill"
                    android:backgroundTint="@color/brand_dark"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="7dp"
                    android:text="@string/history_today_label"
                    android:textColor="@color/brand_cream"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/brand_dark_alpha12" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="4dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="@color/brand_dark"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">
                        <TextView
                            android:id="@+id/tvHistoryKcal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/brand_accent_warm"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-black" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/history_label_kcal_plan"
                            android:textColor="@color/brand_cream"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="@color/brand_primary"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">
                        <TextView
                            android:id="@+id/tvHistoryTraining"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/brand_cream"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-black" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/history_label_day_type"
                            android:textColor="@color/brand_cream"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@color/brand_cream"
                app:cardElevation="0dp"
                app:strokeColor="@color/brand_dark_alpha12"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvHistoryStepsIcon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_status_pill"
                        android:backgroundTint="@color/brand_dark_alpha5"
                        android:gravity="center"
                        android:text="👟"
                        android:textSize="18sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/llStepsKcal"
                        app:layout_constraintStart_toEndOf="@id/tvHistoryStepsIcon"
                        app:layout_constraintTop_toTopOf="parent">

                        <TextView
                            android:id="@+id/tvHistoryStepsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="0"
                            android:textColor="@color/brand_dark"
                            android:textSize="20sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.6"
                            android:letterSpacing="0.05"
                            android:text="@string/history_label_steps_per_day"
                            android:textColor="@color/brand_dark"
                            android:textSize="9sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/llStepsKcal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:orientation="vertical"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <TextView
                            android:id="@+id/tvHistoryStepsBurned"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-black"
                            android:text="+0 kcal"
                            android:textColor="@color/brand_accent_warm"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.8"
                            android:text="@string/history_label_extra_energy"
                            android:textColor="@color/brand_primary"
                            android:textSize="9sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="@color/brand_cream"
                app:cardElevation="0dp"
                app:strokeColor="@color/brand_dark_alpha12"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvHistoryProtein"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/brand_primary"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-black" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_protein"
                            android:textColor="@color/brand_primary"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:alpha="0.7"
                            android:letterSpacing="0.08" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center_vertical"
                        android:background="@color/brand_dark_alpha12" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvHistoryCarbs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/brand_accent_warm"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-black" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_carbs"
                            android:textColor="@color/brand_accent_warm"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:alpha="0.8"
                            android:letterSpacing="0.08" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center_vertical"
                        android:background="@color/brand_dark_alpha12" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvHistoryFat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/brand_accent_deep"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-black" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_fats"
                            android:textColor="@color/brand_accent_deep"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:alpha="0.8"
                            android:letterSpacing="0.08" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHistoryMetrics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="24dp"
                app:cardBackgroundColor="@color/brand_cream"
                app:cardElevation="0dp"
                app:strokeColor="@color/brand_dark_alpha12"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/history_title_symmetry"
                                android:textColor="@color/brand_dark"
                                android:textSize="16sp"
                                android:fontFamily="sans-serif-black" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/history_hint_metrics"
                                android:textColor="@color/brand_primary"
                                android:textSize="11sp"
                                android:alpha="0.7" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvSymmetryStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_status_pill"
                            android:backgroundTint="@color/brand_accent_warm"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="5dp"
                            android:text="@string/history_status_no_data"
                            android:textColor="@color/brand_cream"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08" />
                    </LinearLayout>

                    <cz.uhk.macroflow.history.SymmetryGraphView
                        android:id="@+id/historySymmetryGraph"
                        android:layout_width="match_parent"
                        android:layout_height="300dp"
                        android:layout_marginTop="12dp"
                        android:visibility="invisible" />

                    <LinearLayout
                        android:id="@+id/layoutNoMetrics"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:visibility="visible">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📏"
                            android:textSize="32sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/history_no_metrics_msg"
                            android:textColor="@color/brand_dark"
                            android:textSize="13sp"
                            android:alpha="0.5"
                            android:gravity="center" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="@color/brand_dark"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:text="📐"
                        android:textSize="22sp"
                        android:gravity="center" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/history_tip_title"
                            android:textColor="@color/brand_accent_warm"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/history_tip_desc"
                            android:textColor="@color/brand_cream"
                            android:textSize="12sp"
                            android:alpha="0.75" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/brand_dark_alpha5"
                app:cardBackgroundColor="@color/brand_cream">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BIOLOGIC PROJEKCE"
                                android:textColor="@color/brand_dark"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif-black"
                                android:letterSpacing="0.1" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="7 DNÍ HISTORIE • 7 DNÍ PREDIKCE"
                                android:textColor="@color/brand_dark"
                                android:alpha="0.4"
                                android:textSize="9sp"
                                android:letterSpacing="0.05" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvCurrentTrendTag"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_pill_primary"
                            android:paddingHorizontal="12dp"
