<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardConsumed"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/brand_cream"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/brand_dark_alpha10">

    <LinearLayout
        android:id="@+id/containerContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvItemTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12:45"
            android:textColor="@color/brand_dark_alpha40"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginEnd="16dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvItemName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Název jídla"
                android:textColor="@color/brand_dark"
                android:textSize="17sp"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:id="@+id/tvItemSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="B: 10g · S: 20g · T: 5g"
                android:textColor="@color/brand_dark_alpha40"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvItemKcal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="450 kcal"
            android:textColor="@color/brand_primary"
            android:textSize="15sp"
            android:fontFamily="sans-serif-black" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>