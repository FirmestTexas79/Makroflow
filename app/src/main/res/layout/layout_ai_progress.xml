<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/brand_cream"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Animovaný lístek nebo stylovaný progress -->
    <ProgressBar
        android:id="@+id/aiProgressBar"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:indeterminateTint="@color/brand_primary" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="sans-serif-black"
        android:text="Analyzuji tvé jídlo..."
        android:textColor="@color/brand_dark"
        android:textSize="18sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:alpha="0.7"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:text="MakroFlow AI právě počítá\nnutriční hodnoty z fotky."
        android:textColor="@color/brand_dark"
        android:textSize="14sp" />

</LinearLayout>