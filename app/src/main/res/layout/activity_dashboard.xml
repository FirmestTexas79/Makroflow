<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_cream"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Dekorativní list -->
    <ImageView
        android:id="@+id/leafTop"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_marginTop="-100dp"
        android:layout_marginEnd="-120dp"
        android:src="@drawable/bg_monstera_leaf_1"
        android:alpha="0.10"
        android:rotation="-200"
        app:tint="#283618"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Hamburger ikona — vpravo nahoře, nad vším -->
    <ImageButton
        android:id="@+id/btnOpenDrawer"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginTop="52dp"
        android:layout_marginEnd="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_drawer_user"
        android:elevation="8dp"
        app:tint="@color/brand_dark"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ScrollView s veškerým obsahem -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/dashboardScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingBottom="120dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Pill: typ tréninku -->
            <TextView
                android:id="@+id/tvTrainingStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="64dp"
                android:background="@drawable/bg_status_pill"
                android:backgroundTint="#283618"
                android:paddingHorizontal="24dp"
                android:paddingVertical="10dp"
                android:text="DNES: REST"
                android:textColor="#FEFAE0"
                android:textSize="14sp"
                android:textStyle="bold"
                android:elevation="4dp" />

            <!-- Pozdrav uživatele -->
            <TextView
                android:id="@+id/tvUserGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="6dp"
                android:textSize="13sp"
                android:textColor="@color/brand_primary"
                android:visibility="gone" />

            <!-- Kruhové progress bary -->
            <FrameLayout
                android:id="@+id/circleContainer"
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp">

                <ProgressBar
                    android:id="@+id/progressProtein_Target"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="55dp"
                    android:scaleX="-1"
                    android:alpha="0.4"
                    android:progressDrawable="@drawable/circle_progress_protein" />
                <ProgressBar
                    android:id="@+id/progressProtein_Eaten"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="55dp"
                    android:scaleX="-1"
                    android:progressDrawable="@drawable/circle_progress_protein_light" />
                <ProgressBar
                    android:id="@+id/progressCarbs_Target"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="27.5dp"
                    android:scaleX="-1"
                    android:alpha="0.4"
                    android:progressDrawable="@drawable/circle_progress_carbs" />
                <ProgressBar
                    android:id="@+id/progressCarbs_Eaten"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="27.5dp"
                    android:scaleX="-1"
                    android:progressDrawable="@drawable/circle_progress_carbs_light" />
                <ProgressBar
                    android:id="@+id/progressFat_Target"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="0dp"
                    android:scaleX="-1"
                    android:alpha="0.4"
                    android:progressDrawable="@drawable/circle_progress_fat" />
                <ProgressBar
                    android:id="@+id/progressFat_Eaten"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="0dp"
                    android:scaleX="-1"
                    android:progressDrawable="@drawable/circle_progress_fat_light" />

                <!-- Střed — kalorie -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvCalories"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="0"
                        android:textColor="#283618"
                        android:textSize="24sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KCAL CÍL"
                        android:textColor="#606C38"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />
                </LinearLayout>
            </FrameLayout>

            <!-- Makro karty -->
            <LinearLayout
                android:id="@+id/layoutMacros"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#283618">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:padding="12dp" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Bílkoviny" android:textSize="10sp" android:textColor="#FEFAE0"/>
                        <TextView android:id="@+id/tvValueProtein" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0g / 0g"
                            android:textColor="#FEFAE0" android:textStyle="bold" android:textSize="14sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#606C38">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:padding="12dp" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Sacharidy" android:textSize="10sp" android:textColor="#FEFAE0"/>
                        <TextView android:id="@+id/tvValueCarbs" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0g / 0g"
                            android:textColor="#FEFAE0" android:textStyle="bold" android:textSize="14sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#BC6C25">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:padding="12dp" android:gravity="center" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Tuky" android:textSize="10sp" android:textColor="#FEFAE0"/>
                        <TextView android:id="@+id/tvValueFat" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0g / 0g"
                            android:textColor="#FEFAE0" android:textStyle="bold" android:textSize="14sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Coach karta -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCoachAdvice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#FEFAE0"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeColor="#606C38"
                app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:padding="16dp" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💡 TIP OD TRENÉRA" android:textColor="#606C38"
                        android:textSize="11sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tvCoachMessage" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:layout_marginTop="4dp"
                        android:text="Načítám tvůj stav..." android:textColor="#283618" android:textSize="14sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="8dp" android:text="Klikni pro ranní rituál →"
                        android:textColor="#606C38" android:textSize="11sp" android:alpha="0.7" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Hydratace -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardWater"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#606C38"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:padding="16dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="💧 CÍL HYDRATACE"
                        android:textColor="#FEFAE0" android:textSize="11sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tvWaterValue" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="— L"
                        android:textColor="#FEFAE0" android:textSize="18sp" android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Trenér -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStartTraining"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="#283618"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingHorizontal="20dp">

                    <ImageView
                        android:id="@+id/ivTrainingIcon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_barcode_scan"
                        app:tint="#FEFAE0"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/ivChevron"
                        app:layout_constraintStart_toEndOf="@id/ivTrainingIcon"
                        app:layout_constraintTop_toTopOf="parent">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="CHYTRÝ TRENÉR" android:textColor="#FEFAE0"
                            android:textSize="16sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Analýza hloubky a trajektorie"
                            android:textColor="#DDA15E" android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/ivChevron"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#FEFAE0"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Rituál overlay — mimo ScrollView, překrývá vše -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardRitualOverlay"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginVertical="48dp"
        android:visibility="gone"
        android:elevation="32dp"
        app:cardBackgroundColor="#FEFAE0"
        app:cardCornerRadius="28dp"
        app:cardElevation="30dp"
        app:strokeWidth="2dp"
        app:strokeColor="#283618"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="520dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RANNÍ RITUÁL"
                    android:fontFamily="sans-serif-black"
                    android:textSize="22sp"
                    android:textColor="#283618" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"
                    android:text="Zaznamenej svůj stav pro dnešek"
                    android:textSize="13sp"
                    android:textColor="#606C38" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Dnešní váha"
                    app:suffixText="kg"
                    app:boxStrokeColor="@color/brand_primary"
                    app:hintTextColor="@color/brand_primary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etWeight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="@color/brand_dark" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="20dp" android:text="Míra energie (1–5)"
                    android:textColor="@color/brand_dark" android:textStyle="bold" android:textSize="13sp" />
                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderEnergy"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:valueFrom="1.0" android:valueTo="5.0" android:stepSize="1.0"
                    app:thumbColor="@color/brand_primary" app:trackColorActive="@color/brand_primary" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="12dp" android:text="Kvalita spánku (1–5)"
                    android:textColor="@color/brand_dark" android:textStyle="bold" android:textSize="13sp" />
                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderSleep"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:valueFrom="1.0" android:valueTo="5.0" android:stepSize="1.0"
                    app:thumbColor="@color/brand_accent_warm" app:trackColorActive="@color/brand_accent_warm" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="12dp" android:text="Jak moc jsi hladový? (1–5)"
                    android:textColor="@color/brand_dark" android:textStyle="bold" android:textSize="13sp" />
                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderHunger"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:valueFrom="1.0" android:valueTo="5.0" android:stepSize="1.0"
                    app:thumbColor="@color/brand_dark" app:trackColorActive="@color/brand_primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveRitual"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="24dp"
                    android:text="ULOŽIT A ZAČÍT"
                    android:backgroundTint="#283618"
                    app:cornerRadius="16dp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>