<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_cream"
    android:clipChildren="false"
    android:clipToPadding="false">

    <ImageView
        android:id="@+id/leafTop"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:layout_marginTop="-100dp"
        android:layout_marginEnd="-120dp"
        android:src="@drawable/bg_monstera_leaf_1"
        android:alpha="0.10"
        android:rotation="-200"
        app:tint="#283618"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvTrainingStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:background="@drawable/bg_status_pill"
        android:backgroundTint="#283618"
        android:paddingHorizontal="24dp"
        android:paddingVertical="10dp"
        android:text="DNES: LEGS"
        android:textColor="#FEFAE0"
        android:textSize="14sp"
        android:textStyle="bold"
        android:elevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:id="@+id/circleContainer"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTrainingStatus">

        <ProgressBar
            android:id="@+id/progressProtein"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="60dp"
            android:scaleX="-1"
            android:progressDrawable="@drawable/circle_progress_protein" />

        <ProgressBar
            android:id="@+id/progressCarbs"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="40dp"
            android:scaleX="-1"
            android:progressDrawable="@drawable/circle_progress_carbs" />

        <ProgressBar
            android:id="@+id/progressFat"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="44dp"
            android:scaleX="-1"
            android:progressDrawable="@drawable/circle_progress_fat" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvCalories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="3730"
                android:textColor="#283618"
                android:textSize="48sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KCAL CÍL"
                android:textColor="#606C38"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/layoutMacros"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/circleContainer">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#283618">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:gravity="center" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bílkoviny" android:textSize="10sp" android:textColor="#FEFAE0"/>
                <TextView android:id="@+id/tvValueProtein" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="189g" android:textColor="#FEFAE0" android:textStyle="bold" android:textSize="16sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#606C38">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:gravity="center" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sacharidy" android:textSize="10sp" android:textColor="#FEFAE0"/>
                <TextView android:id="@+id/tvValueCarbs" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="600g" android:textColor="#FEFAE0" android:textStyle="bold" android:textSize="16sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="4dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#BC6C25">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" android:gravity="center" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tuky" android:textSize="10sp" android:textColor="#FEFAE0"/>
                <TextView android:id="@+id/tvValueFat" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="63g" android:textColor="#FEFAE0" android:textStyle="bold" android:textSize="16sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardCoachAdvice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="#FEFAE0"
        app:cardCornerRadius="20dp"
        app:cardElevation="2dp"
        app:strokeColor="#606C38"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/layoutMacros">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💡 TIP OD TRENÉRA" android:textColor="#606C38" android:textSize="11sp" android:textStyle="bold" />
            <TextView android:id="@+id/tvCoachMessage" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Načítám tvůj stav..." android:textColor="#283618" android:textSize="14sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardWater"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="#606C38"
        app:cardCornerRadius="20dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/cardCoachAdvice">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💧 CÍL HYDRATACE"
                android:textColor="#FEFAE0"
                android:textSize="11sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvWaterValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3.5 L"
                android:textColor="#FEFAE0"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardRitualOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:visibility="gone"
        app:cardBackgroundColor="#FEFAE0"
        app:cardCornerRadius="28dp"
        app:cardElevation="30dp"
        app:strokeWidth="2dp"
        app:strokeColor="#283618"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RANNÍ RITUÁL"
                android:fontFamily="sans-serif-black"
                android:textSize="22sp"
                android:textColor="#283618" />

            <EditText
                android:id="@+id/etWeight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:hint="Váha (kg)"
                android:inputType="numberDecimal"
                android:text="83.0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Míra energie (1-5)"
                android:textColor="@color/brand_dark" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderEnergy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="1.0"
                android:valueTo="5.0"
                android:stepSize="1.0"
                app:thumbColor="@color/brand_primary"
                app:trackColorActive="@color/brand_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Kvalita spánku (1-5)"
                android:textColor="@color/brand_dark" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderSleep"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="1.0"
                android:valueTo="5.0"
                android:stepSize="1.0"
                app:thumbColor="@color/brand_accent_warm"
                app:trackColorActive="@color/brand_accent_warm" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Jak moc jsi hladový? (1-5)"
                android:textColor="@color/brand_dark" />

            <com.google.android.material.slider.Slider
                android:id="@+id/sliderHunger"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="1.0"
                android:valueTo="5.0"
                android:stepSize="1.0"
                app:thumbColor="@color/brand_dark"
                app:trackColorActive="@color/brand_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveRitual"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="20dp"
                android:text="ULOŽIT A ZAČÍT"
                android:backgroundTint="#283618"
                app:cornerRadius="16dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>