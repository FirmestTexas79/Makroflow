<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@color/brand_cream">

    <TextView
        android:id="@+id/tvMacroName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bílkoviny"
        android:textColor="@color/brand_dark"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.02" />

    <ProgressBar
        android:id="@+id/macroProgress"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        android:progress="70"
        android:progressDrawable="@drawable/macro_progress_gradient" />

    <TextView
        android:id="@+id/tvMacroValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="120g / 180g"
        android:textColor="@color/brand_primary"
        android:textSize="11sp"
        android:fontFamily="monospace" />

</LinearLayout>