<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardPokemonDetail"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="@color/brand_cream"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:strokeColor="#20283618"
    app:strokeWidth="1.5dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="16dp">

            <ImageView
                android:id="@+id/ivPokemonSprite"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:scaleType="fitCenter"
                android:src="@drawable/pokemon_diglett" />

            <TextView
                android:id="@+id/tvPokemonName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/brand_dark"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black"
                android:textAllCaps="true"
                android:text="DIGLETT" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp"
                android:paddingHorizontal="4dp">

                <TextView
                    android:id="@+id/tvPokemonLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/brand_accent_deep"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-black"
                    android:text="Lv.1" />

                <ProgressBar
                    android:id="@+id/pbPokemonXp"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:progress="30"
                    android:progressTint="@color/brand_accent_warm"
                    android:progressBackgroundTint="#1A283618" />
            </LinearLayout>

            <View
                android:id="@+id/separator"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#1F283618" />

            <LinearLayout
                android:id="@+id/llPokemonActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnPinToBar"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginHorizontal="6dp"
                    android:background="@drawable/bg_status_pill"
                    android:backgroundTint="#1A606C38"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@android:drawable/ic_menu_send"
                    app:tint="@color/brand_primary" />

                <ImageButton
                    android:id="@+id/btnUnpinFromBar"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginHorizontal="6dp"
                    android:background="@drawable/bg_status_pill"
                    android:backgroundTint="#1AE9B072"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@android:drawable/ic_menu_revert"
                    app:tint="@color/brand_accent_warm" />

                <ImageButton
                    android:id="@+id/btnDeletePokemon"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginHorizontal="6dp"
                    android:background="@drawable/bg_status_pill"
                    android:backgroundTint="#1ABC6C25"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@android:drawable/ic_menu_delete"
                    app:tint="@color/brand_accent_deep" />

            </LinearLayout>

        </LinearLayout>

        <ImageButton
            android:id="@+id/btnLock"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="end|top"
            android:layout_margin="10dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:src="@android:drawable/ic_lock_lock"
            app:tint="@color/brand_accent_deep" />

    </FrameLayout>
</com.google.android.material.card.MaterialCardView>