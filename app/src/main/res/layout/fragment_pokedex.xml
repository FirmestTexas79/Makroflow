<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/brand_cream">

    <LinearLayout
        android:id="@+id/pokedexTopSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/brand_cream">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="36dp"
            android:paddingBottom="6dp">

            <TextView
                android:id="@+id/tvPokedexBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_pill"
                android:backgroundTint="@color/brand_primary"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="@string/pokedex_region_label"
                android:textColor="@color/brand_cream"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.12"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvPokedexTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif-black"
                android:text="@string/pokedex_title"
                android:textColor="@color/brand_dark"
                android:textSize="34sp"
                android:lineSpacingMultiplier="0.9"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvPokedexBadge" />

            <TextView
                android:id="@+id/tvPokedexSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/pokedex_subtitle"
                android:textColor="@color/brand_primary"
                android:textSize="13sp"
                android:alpha="0.75"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvPokedexTitle" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="@color/brand_dark"
            app:cardElevation="4dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="120dp"
                    android:layout_height="120dp">
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_status_pill"
                        android:backgroundTint="@color/brand_cream_alpha10" />
                    <ImageView
                        android:id="@+id/ivDetailSprite"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:layout_gravity="center"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_home" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:id="@+id/tvDetailNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/pokedex_number_placeholder"
                        android:textColor="@color/brand_cream_alpha50"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-black"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/tvDetailName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="sans-serif-black"
                        android:text="@string/pokemon_default_name"
                        android:textColor="@color/brand_cream"
                        android:textSize="24sp" />

                    <TextView
                        android:id="@+id/tvDetailType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_status_pill"
                        android:backgroundTint="@color/brand_accent_warm"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="5dp"
                        android:text="@string/pokedex_type_placeholder"
                        android:textColor="@color/brand_dark"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:id="@+id/tvDetailMacro"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/pokedex_macro_desc_placeholder"
                        android:textColor="@color/brand_cream_alpha80"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3"
                        android:maxLines="3"
                        android:ellipsize="end" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTestEvo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/pokedex_btn_evo_test"
                        android:visibility="gone"
                        android:textColor="@color/brand_dark"
                        android:fontFamily="sans-serif-black"
                        app:backgroundTint="@color/brand_accent_warm"
                        app:cornerRadius="12dp" />

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="8dp">
            <View android:layout_width="0dp" android:layout_height="1dp"
                android:layout_weight="1" android:background="@color/brand_dark_alpha12" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp" android:text="@string/pokedex_list_separator"
                android:textColor="@color/brand_primary" android:textSize="10sp" android:fontFamily="sans-serif-black"
                android:letterSpacing="0.14" />
            <View android:layout_width="0dp" android:layout_height="1dp"
                android:layout_weight="1" android:background="@color/brand_dark_alpha12" />
        </LinearLayout>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPokedex"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="14dp"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        android:overScrollMode="never" />

</LinearLayout>