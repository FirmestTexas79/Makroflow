<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FEFAE0">

    <LinearLayout
        android:id="@+id/pokedexTopSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FEFAE0">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="36dp"
            android:paddingBottom="6dp">

            <TextView
                android:id="@+id/tvPokedexBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_pill"
                android:backgroundTint="#606C38"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="KANTO REGION"
                android:textColor="#FEFAE0"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvPokedexTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif-black"
                android:text="Pokédex"
                android:textColor="#283618"
                android:textSize="34sp"
                android:lineSpacingMultiplier="0.9"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvPokedexBadge" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Chyť je všechny — tréninkem a disciplínou."
                android:textColor="#606C38"
                android:textSize="13sp"
                android:alpha="0.75"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvPokedexTitle" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="#283618"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <FrameLayout
                    android:layout_width="120dp"
                    android:layout_height="120dp">
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_status_pill"
                        android:backgroundTint="#1AFEFAE0" />
                    <ImageView
                        android:id="@+id/ivDetailSprite"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:layout_gravity="center"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_home" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:id="@+id/tvDetailNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="#001"
                        android:textColor="#80FEFAE0"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/tvDetailName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="sans-serif-black"
                        android:text="Bulbasaur"
                        android:textColor="#FEFAE0"
                        android:textSize="24sp" />

                    <TextView
                        android:id="@+id/tvDetailType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_status_pill"
                        android:backgroundTint="#DDA15E"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="5dp"
                        android:text="TRÁVA / JED"
                        android:textColor="#283618"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDetailMacro"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Základní stavební kámen jídelníčku. Nezapomínej na listovou zeleninu."
                        android:textColor="#BDFEFAE0"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3"
                        android:maxLines="3"
                        android:ellipsize="end" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTestEvo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Test Evoluce"
                        android:visibility="gone"
                        android:textColor="#283618"
                        app:backgroundTint="#DDA15E"
                        app:cornerRadius="12dp" />

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="8dp">
            <View android:layout_width="0dp" android:layout_height="1dp"
                android:layout_weight="1" android:background="#20283618" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp" android:text="KANTO DEX"
                android:textColor="#606C38" android:textSize="10sp" android:textStyle="bold"
                android:letterSpacing="0.14" />
            <View android:layout_width="0dp" android:layout_height="1dp"
                android:layout_weight="1" android:background="#20283618" />
        </LinearLayout>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPokedex"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="14dp"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        android:overScrollMode="never" />

</LinearLayout>