<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinatorPlan"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_cream">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="120dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                android:paddingTop="56dp"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/tvWeekLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_status_pill"
                    android:backgroundTint="@color/brand_accent_deep"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="@string/label_weekly_plan"
                    android:textColor="@color/brand_cream"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="12dp"
                    android:fontFamily="sans-serif-black"
                    android:text="@string/training_schedule_title"
                    android:textColor="@color/brand_dark"
                    android:textSize="32sp"
                    android:lineSpacingMultiplier="0.85"
                    app:autoSizeMaxTextSize="34sp"
                    app:autoSizeMinTextSize="22sp"
                    app:autoSizeStepGranularity="2sp"
                    app:autoSizeTextType="uniform"
                    app:layout_constraintEnd_toStartOf="@+id/llStepsCounter"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvWeekLabel" />

                <LinearLayout
                    android:id="@+id/llStepsCounter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_status_pill"
                    android:backgroundTint="@color/brand_dark_alpha5"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    app:layout_constraintBottom_toBottomOf="@+id/tvTitle"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/tvTitle">

                    <!-- ✅ ID přidáno: tvStepsEmoji -->
                    <TextView
                        android:id="@+id/tvStepsEmoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👟"
                        android:textSize="18sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:id="@+id/tvTotalStepsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/brand_dark"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-black" />

                        <!-- ✅ ID přidáno: tvFatBurnedLabel -->
                        <TextView
                            android:id="@+id/tvFatBurnedLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔥 0.0g TUKU"
                            android:textColor="@color/brand_accent_deep"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/training_schedule_subtitle"
                    android:textColor="@color/brand_primary"
                    android:textSize="13sp"
                    android:alpha="0.8"
                    app:layout_constraintEnd_toEndOf="@+id/tvTitle"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvTitle" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- POWER / KARDIO mode toggle -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleModeGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                app:selectionRequired="true"
                app:singleSelection="true"
                app:checkedButton="@+id/btnModePower">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnModePower"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="⚡ POWER"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="28dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="20dp"
                    app:strokeColor="@color/brand_dark_alpha20" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnModeKardio"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="🏃 KARDIO"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="28dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="20dp"
                    app:strokeColor="@color/brand_dark_alpha20" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- Stat cards — 5 bloků, FULL/STAIRS jako první -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="20dp">

                <!-- FULL / STAIRS -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardStatFull"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="#5C4033"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingVertical="14dp">
                        <TextView
                            android:id="@+id/tvStatFullCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/brand_cream"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-black" />
                        <TextView
                            android:id="@+id/tvStatFullLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="FULL"
                            android:textColor="@color/brand_cream"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- PUSH / BĚH -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardStatPush"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="@color/brand_dark"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingVertical="14dp">
                        <TextView
                            android:id="@+id/tvStatPushCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/brand_cream"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-black" />
                        <TextView
                            android:id="@+id/tvStatPushLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PUSH"
                            android:textColor="@color/brand_cream"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- PULL / ŠVIH -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardStatPull"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="@color/brand_accent_warm"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingVertical="14dp">
                        <TextView
                            android:id="@+id/tvStatPullCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/brand_cream"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-black" />
                        <TextView
                            android:id="@+id/tvStatPullLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PULL"
                            android:textColor="@color/brand_cream"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- LEGS / KOLO -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardStatLegs"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="@color/brand_accent_deep"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingVertical="14dp">
                        <TextView
                            android:id="@+id/tvStatLegsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/brand_cream"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-black" />
                        <TextView
                            android:id="@+id/tvStatLegsLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LEGS"
                            android:textColor="@color/brand_cream"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- REST / OFF -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardStatRest"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="@color/brand_cream"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/brand_dark_alpha20"
                    app:strokeWidth="1.5dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:paddingVertical="14dp">
                        <TextView
                            android:id="@+id/tvStatRestCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/brand_dark"
                            android:textSize="22sp"
                            android:fontFamily="sans-serif-black" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="REST"
                            android:textColor="@color/brand_primary"
                            android:textSize="8sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp">
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="@color/brand_dark_alpha12" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginHorizontal="12dp" android:text="@string/label_setup_days" android:textColor="@color/brand_primary" android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.14" />
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="@color/brand_dark_alpha12" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTrainingPlan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="@color/brand_dark"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="36dp" android:layout_height="wrap_content" android:text="💡" android:textSize="22sp" android:gravity="center" />
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:orientation="vertical">
                        <TextView android:id="@+id/tvTipTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/tip_macros_adapt_title" android:textColor="@color/brand_accent_warm" android:textSize="13sp" android:textStyle="bold" />
                        <TextView android:id="@+id/tvTipLine1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:text="@string/tip_push_desc" android:textColor="@color/brand_cream" android:textSize="12sp" />
                        <TextView android:id="@+id/tvTipLine2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:text="@string/tip_pull_desc" android:textColor="@color/brand_cream" android:textSize="12sp" />
                        <TextView android:id="@+id/tvTipLine3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="@string/tip_legs_desc" android:textColor="@color/brand_cream" android:textSize="12sp" />
                        <TextView android:id="@+id/tvTipLine4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:text="@string/tip_off_desc" android:textColor="@color/brand_cream" android:textSize="12sp" android:alpha="0.8" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>