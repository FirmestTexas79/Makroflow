<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FEFAE0">

        <!-- Fragmenty — celá obrazovka (pod status barem systém odsadí sám) -->
        <FrameLayout
            android:id="@+id/nav_host_fragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Spodní navigace -->
        <RelativeLayout
            android:id="@+id/bottomNavLayout"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_alignParentBottom="true"
            android:clipChildren="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_alignParentBottom="true"
                android:background="@drawable/bg_bottom_nav_with_curve"
                android:orientation="horizontal">

                <com.google.android.material.bottomnavigation.BottomNavigationView
                    android:id="@+id/bottomNavigation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:background="@android:color/transparent"
                    app:elevation="0dp"
                    app:itemIconSize="28dp"
                    app:itemPaddingTop="10dp"
                    app:itemIconTint="#FEFAE0"
                    app:itemTextColor="#FEFAE0"
                    app:labelVisibilityMode="labeled"
                    app:menu="@menu/bottom_menu" />
            </LinearLayout>

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_centerHorizontal="true"
                android:src="@drawable/ic_logo_white"
                app:backgroundTint="#283618"
                app:borderWidth="3dp"
                app:elevation="10dp"
                app:fabCustomSize="68dp"
                app:maxImageSize="32dp"
                app:strokeColor="#606C38"
                app:tint="#FEFAE0" />
        </RelativeLayout>

        <!-- TopBar — ikona profilu, pravý horní roh, vždy nad vším -->
        <FrameLayout
            android:id="@+id/topBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="48dp"
            android:layout_marginEnd="20dp">

            <ImageButton
                android:id="@+id/btnOpenDrawer"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_status_pill"
                android:backgroundTint="#15283618"
                android:src="@drawable/ic_drawer_user"
                android:contentDescription="Menu"
                android:padding="10dp" />

        </FrameLayout>

    </RelativeLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:fitsSystemWindows="true"
        android:background="@color/brand_cream"
        app:headerLayout="@layout/drawer_header"
        app:menu="@menu/drawer_menu"
        app:itemTextColor="@color/brand_dark"
        app:itemIconTint="@color/brand_primary"
        app:itemTextAppearance="@style/DrawerItemText"
        app:itemBackground="@drawable/drawer_item_background" />

</androidx.drawerlayout.widget.DrawerLayout>