<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_cream"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/setupMainLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="44dp"
        android:paddingBottom="160dp"
        android:paddingHorizontal="20dp">

        <!-- Nadpis -->
        <TextView
            android:id="@+id/tvProfileTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NASTAVENÍ PROFILU"
            android:textColor="@color/brand_dark"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Toggle pohlaví -->
        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleGender"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/tvProfileTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMale"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/man"
                android:textColor="@color/brand_dark"
                app:strokeColor="@color/brand_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFemale"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/woman"
                android:textColor="@color/brand_dark"
                app:strokeColor="@color/brand_primary" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- Vstupní pole -->
        <LinearLayout
            android:id="@+id/inputsLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/toggleGender"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/weight"
                app:suffixText="kg"
                app:suffixTextColor="@color/brand_dark"
                app:boxStrokeColor="@color/brand_primary"
                app:hintTextColor="@color/brand_primary"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etWeight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal"
                    android:textColor="@color/brand_dark" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/height"
                app:suffixText="cm"
                app:suffixTextColor="@color/brand_dark"
                app:boxStrokeColor="@color/brand_primary"
                app:hintTextColor="@color/brand_primary"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etHeight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/brand_dark" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/age"
                app:suffixText="let"
                app:suffixTextColor="@color/brand_dark"
                app:boxStrokeColor="@color/brand_primary"
                app:hintTextColor="@color/brand_primary"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etAge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:textColor="@color/brand_dark" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- Kruh životního stylu -->
        <FrameLayout
            android:id="@+id/circleLifestyle"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_marginTop="40dp"
            app:layout_constraintTop_toBottomOf="@id/inputsLayout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/partLezerni"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_low"
                android:scaleType="fitCenter"
                android:alpha="0.3"
                app:tint="@color/brand_primary" />

            <ImageView
                android:id="@+id/partAktivni"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_med"
                android:scaleType="fitCenter"
                android:alpha="0.3"
                app:tint="@color/brand_accent_warm" />

            <ImageView
                android:id="@+id/partSportovec"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_high"
                android:scaleType="fitCenter"
                android:alpha="0.3"
                app:tint="@color/brand_accent_deep" />

            <ImageView
                android:id="@+id/iconCenterLow"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/img_low"
                android:alpha="0"
                app:tint="@color/brand_dark" />

            <ImageView
                android:id="@+id/iconCenterMed"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/img_med"
                android:alpha="0"
                app:tint="@color/brand_dark" />

            <ImageView
                android:id="@+id/iconCenterHigh"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/img_high"
                android:alpha="0"
                app:tint="@color/brand_dark" />

            <View android:id="@+id/clickLezerni"
                android:layout_width="90dp" android:layout_height="90dp"
                android:layout_gravity="top|start" />
            <View android:id="@+id/clickAktivni"
                android:layout_width="90dp" android:layout_height="90dp"
                android:layout_gravity="top|end" />
            <View android:id="@+id/clickSportovec"
                android:layout_width="180dp" android:layout_height="70dp"
                android:layout_gravity="bottom" />
        </FrameLayout>

        <!-- Popis životního stylu -->
        <TextView
            android:id="@+id/tvLifestyleDesc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textAlignment="center"
            android:textSize="18sp"
            android:textColor="@color/brand_dark"
            android:textStyle="bold"
            android:visibility="invisible"
            app:layout_constraintTop_toBottomOf="@id/circleLifestyle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Karta tělesných měr -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardOptionalMetrics"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/brand_cream"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/brand_dark"
            app:layout_constraintTop_toBottomOf="@id/tvLifestyleDesc"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/moje_obvody"
                    android:textColor="@color/brand_dark"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_high"
                    app:tint="@color/brand_dark" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── SEKCE ÚČTU ────────────────────────────── -->

        <View
            android:id="@+id/dividerAccount"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="28dp"
            android:background="#1A283618"
            app:layout_constraintTop_toBottomOf="@id/cardOptionalMetrics"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvAccountTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="ÚČET"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:textColor="@color/brand_primary"
            app:layout_constraintTop_toBottomOf="@id/dividerAccount"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Karta s emailem -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAccountInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="@color/brand_cream"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#1A283618"
            app:layout_constraintTop_toBottomOf="@id/tvAccountTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/ic_drawer_user"
                    app:tint="@color/brand_primary" />

                <TextView
                    android:id="@+id/tvUserEmail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Offline režim"
                    android:textSize="14sp"
                    android:textColor="@color/brand_dark"
                    android:ellipsize="end"
                    android:maxLines="1" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Přihlásit / Odhlásit -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSignOut"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:text="Přihlásit se"
            android:textColor="@color/brand_cream"
            android:textStyle="bold"
            app:backgroundTint="@color/brand_dark"
            app:cornerRadius="16dp"
            app:layout_constraintTop_toBottomOf="@id/cardAccountInfo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ── ULOŽIT ────────────────────────────────── -->

        <View
            android:id="@+id/dividerSave"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="28dp"
            android:background="#1A283618"
            app:layout_constraintTop_toBottomOf="@id/btnSignOut"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_marginTop="20dp"
            android:text="@string/save_all"
            android:textColor="@color/brand_cream"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/brand_primary"
            app:cornerRadius="16dp"
            app:layout_constraintTop_toBottomOf="@id/dividerSave"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>