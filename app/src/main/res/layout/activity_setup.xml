<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_cream">

    <ImageView
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-50dp"
        android:layout_marginEnd="-60dp"
        android:src="@drawable/bg_monstera_leaf_1"
        android:alpha="0.07"
        android:rotation="-15"
        app:tint="@color/brand_dark" />

    <ImageView
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-25dp"
        android:layout_marginBottom="140dp"
        android:src="@drawable/bg_monstera_leaf_2"
        android:alpha="0.06"
        android:rotation="55"
        app:tint="@color/brand_primary" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        android:overScrollMode="never">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/setupMainLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="56dp"
            android:paddingBottom="40dp">

            <TextView
                android:id="@+id/tvProfileBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_pill"
                android:backgroundTint="@color/brand_primary"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:text="@string/setup_badge_profile"
                android:textColor="@color/brand_cream"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvProfileTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="sans-serif-black"
                android:text="@string/setup_title"
                android:textColor="@color/brand_dark"
                android:textSize="42sp"
                android:lineSpacingMultiplier="0.9"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvProfileBadge" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/setup_subtitle"
                android:textColor="@color/brand_primary"
                android:textSize="13sp"
                android:alpha="0.75"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvProfileTitle" />

            <LinearLayout
                android:id="@+id/dividerBasic"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="28dp"
                app:layout_constraintTop_toBottomOf="@id/tvProfileTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="@color/brand_dark_alpha12" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp" android:text="@string/setup_section_basic"
                    android:textColor="@color/brand_primary" android:textSize="10sp" android:textStyle="bold"
                    android:letterSpacing="0.14" />
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="@color/brand_dark_alpha12" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleGender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:layout_constraintTop_toBottomOf="@id/dividerBasic"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMale"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="140dp"
                    android:layout_height="48dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/man"
                    android:textColor="@color/brand_dark"
                    app:strokeColor="@color/brand_primary"
                    app:cornerRadius="24dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFemale"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="140dp"
                    android:layout_height="48dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/woman"
                    android:textColor="@color/brand_dark"
                    app:strokeColor="@color/brand_primary"
                    app:cornerRadius="24dp" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <LinearLayout
                android:id="@+id/dividerGoal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="28dp"
                app:layout_constraintTop_toBottomOf="@id/toggleGender"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="@color/brand_dark_alpha12" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp" android:text="AKTUÁLNÍ CÍL"
                    android:textColor="@color/brand_primary" android:textSize="10sp" android:textStyle="bold"
                    android:letterSpacing="0.14" />
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="@color/brand_dark_alpha12" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleGoal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:checkedButton="@+id/btnMaintain"
                app:layout_constraintTop_toBottomOf="@id/dividerGoal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCut"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="CUT" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMaintain"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="MAINTAIN" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBulk"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="BULK" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <LinearLayout
                android:id="@+id/inputsLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/toggleGoal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilWeight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/weight"
                    app:suffixText="kg"
                    app:boxStrokeColor="@color/brand_primary"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etWeight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="@color/brand_dark" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilHeight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/height"
                    app:suffixText="cm"
                    app:boxStrokeColor="@color/brand_primary"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etHeight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textColor="@color/brand_dark" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilAge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/age"
                    app:suffixText="@string/unit_years"
                    app:boxStrokeColor="@color/brand_primary"
                    app:boxCornerRadiusTopStart="14dp"
                    app:boxCornerRadiusTopEnd="14dp"
                    app:boxCornerRadiusBottomStart="14dp"
                    app:boxCornerRadiusBottomEnd="14dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAge"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textColor="@color/brand_dark" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>



            <LinearLayout
                android:id="@+id/dividerLifestyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="28dp"
                app:layout_constraintTop_toBottomOf="@id/inputsLayout"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="@color/brand_dark_alpha12" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp" android:text="@string/setup_section_lifestyle"
                    android:textColor="@color/brand_primary" android:textSize="10sp" android:textStyle="bold"
                    android:letterSpacing="0.14" />
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="@color/brand_dark_alpha12" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/circleLifestyle"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/dividerLifestyle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView android:id="@+id/partLezerni"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:src="@drawable/ic_low" android:scaleType="fitCenter"
                    android:alpha="0.3" app:tint="@color/brand_primary" />
                <ImageView android:id="@+id/partAktivni"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:src="@drawable/ic_med" android:scaleType="fitCenter"
                    android:alpha="0.3" app:tint="@color/brand_accent_warm" />
                <ImageView android:id="@+id/partSportovec"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:src="@drawable/ic_high" android:scaleType="fitCenter"
                    android:alpha="0.3" app:tint="@color/brand_accent_deep" />

                <ImageView android:id="@+id/iconCenterLow"
                    android:layout_width="52dp" android:layout_height="52dp"
                    android:layout_gravity="center" android:src="@drawable/img_low"
                    android:alpha="0" app:tint="@color/brand_dark" />
                <ImageView android:id="@+id/iconCenterMed"
                    android:layout_width="52dp" android:layout_height="52dp"
                    android:layout_gravity="center" android:src="@drawable/img_med"
                    android:alpha="0" app:tint="@color/brand_dark" />
                <ImageView android:id="@+id/iconCenterHigh"
                    android:layout_width="52dp" android:layout_height="52dp"
                    android:layout_gravity="center" android:src="@drawable/img_high"
                    android:alpha="0" app:tint="@color/brand_dark" />

                <View android:id="@+id/clickLezerni"
                    android:layout_width="80dp" android:layout_height="80dp"
                    android:layout_gravity="top|start" />
                <View android:id="@+id/clickAktivni"
                    android:layout_width="80dp" android:layout_height="80dp"
                    android:layout_gravity="top|end" />
                <View android:id="@+id/clickSportovec"
                    android:layout_width="160dp" android:layout_height="60dp"
                    android:layout_gravity="bottom" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvLifestyleDesc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textAlignment="center"
                android:textSize="16sp"
                android:textColor="@color/brand_dark"
                android:textStyle="bold"
                android:visibility="invisible"
                app:layout_constraintTop_toBottomOf="@id/circleLifestyle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStepGoal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/brand_cream"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/brand_dark_alpha12"
                app:layout_constraintTop_toBottomOf="@id/tvLifestyleDesc"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/setup_label_steps"
                            android:textColor="@color/brand_primary"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/tvStepGoalValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/setup_steps_default"
                            android:textColor="@color/brand_dark"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderStepGoal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:valueFrom="2000"
                        android:valueTo="20000"
                        android:stepSize="500"
                        android:value="6000"
                        app:thumbColor="@color/brand_primary"
                        app:trackColorActive="@color/brand_dark"
                        app:trackColorInactive="@color/brand_dark_alpha20" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOptionalMetrics"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/brand_dark"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/cardStepGoal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/setup_label_measurements"
                            android:textColor="@color/brand_accent_warm"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/moje_obvody"
                            android:textColor="@color/brand_cream"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-black" />
                    </LinearLayout>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/brand_cream" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/dividerAccount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="28dp"
                app:layout_constraintTop_toBottomOf="@id/cardOptionalMetrics"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="@color/brand_dark_alpha12" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp" android:text="@string/setup_section_account"
                    android:textColor="@color/brand_primary" android:textSize="10sp" android:textStyle="bold"
                    android:letterSpacing="0.14" />
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="@color/brand_dark_alpha12" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAccountInfo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/brand_cream"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/brand_dark_alpha12"
                app:layout_constraintTop_toBottomOf="@id/dividerAccount"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="14dp"
                        android:src="@drawable/ic_drawer_user"
                        app:tint="@color/brand_primary" />
                    <TextView
                        android:id="@+id/tvUserEmail"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/setup_offline_mode"
                        android:textSize="14sp"
                        android:textColor="@color/brand_dark"
                        android:ellipsize="end"
                        android:maxLines="1" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSignOut"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:text="@string/setup_btn_login"
                android:textColor="@color/brand_cream"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="@color/brand_dark"
                app:cornerRadius="16dp"
                app:layout_constraintTop_toBottomOf="@id/cardAccountInfo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btnSave"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="112dp"
        android:text="@string/btn_save"
        android:textColor="@color/brand_cream"
        android:textSize="13sp"
        android:textStyle="bold"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:icon="@drawable/ic_save"
        app:iconTint="@color/brand_cream"
        app:iconSize="22dp"
        app:backgroundTint="@color/brand_primary"
        app:cornerRadius="28dp"
        app:elevation="12dp"
        app:fabSize="normal" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>