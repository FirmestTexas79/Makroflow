<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:background="#FEFAE0"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="12dp">

    <RelativeLayout
        android:layout_width="46dp"
        android:layout_height="46dp">

        <ImageView
            android:id="@+id/ivNotificationPokemon"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_centerInParent="true"
            android:scaleType="centerInside"
            android:src="@drawable/ic_logo_black" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="10dp"
        android:orientation="vertical">
        <TextView
            android:id="@+id/tvNotificationTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CHARIZARD"
            android:textStyle="bold"
            android:textSize="13sp"
            android:textColor="#283618" />
        <TextView
            android:id="@+id/tvNotificationSteps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 / 6000"
            android:textColor="#606C38"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="vertical">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TRÉNINK"
            android:textStyle="bold"
            android:textColor="#BC6C25"
            android:textSize="9sp" />
        <TextView
            android:id="@+id/tvNotificationStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="17:30"
            android:textColor="#283618"
            android:textStyle="bold"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>