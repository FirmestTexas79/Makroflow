<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mapRootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <RelativeLayout
        android:id="@+id/mapMainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/mapBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/poketown" />

        <View android:id="@+id/hotspotForest" android:layout_width="52dp" android:layout_height="94dp" android:layout_alignParentTop="true" android:layout_centerHorizontal="true" android:layout_marginTop="32dp" android:background="@android:color/transparent" />
        <View android:id="@+id/hotspotPokedex" android:layout_width="93dp" android:layout_height="63dp" android:layout_alignParentEnd="true" android:layout_alignParentBottom="true" android:layout_marginEnd="67dp" android:layout_marginBottom="657dp" android:background="@android:color/transparent" />
        <View android:id="@+id/hotspotHome" android:layout_width="105dp" android:layout_height="67dp" android:layout_alignParentStart="true" android:layout_alignParentBottom="true" android:layout_marginStart="46dp" android:layout_marginBottom="654dp" android:background="@android:color/transparent" />
        <View android:id="@+id/hotspotShop" android:layout_width="105dp" android:layout_height="81dp" android:layout_alignParentStart="true" android:layout_alignParentBottom="true" android:layout_marginStart="235dp" android:layout_marginBottom="504dp" android:background="@android:color/transparent" />

        <ImageView
            android:id="@+id/ashView"
            android:layout_width="48dp"
            android:layout_height="72dp"
            android:scaleType="fitCenter"
            android:elevation="10dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="60dp"
            android:layout_marginEnd="16dp"
            android:orientation="vertical"
            android:elevation="15dp">
            <ImageButton android:id="@+id/btnExitMap" android:layout_width="44dp" android:layout_height="44dp" android:layout_marginBottom="12dp" android:background="@drawable/bg_status_pill" android:backgroundTint="@color/brand_dark" android:padding="12dp" android:scaleType="fitCenter" android:src="@android:drawable/ic_menu_close_clear_cancel" app:tint="@color/brand_cream" android:elevation="4dp" />
            <ImageButton android:id="@+id/btnStartTutorial" android:layout_width="44dp" android:layout_height="44dp" android:background="@drawable/bg_status_pill" android:backgroundTint="@color/brand_primary" android:padding="12dp" android:scaleType="fitCenter" android:src="@android:drawable/ic_menu_help" app:tint="@color/brand_cream" android:elevation="4dp" />
        </LinearLayout>

        <FrameLayout android:id="@+id/mapFragmentContainer" android:layout_width="match_parent" android:layout_height="match_parent" android:elevation="20dp" />
    </RelativeLayout>

    <FrameLayout
        android:id="@+id/tutorialOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:elevation="100dp">

        <ImageView
            android:id="@+id/tutorialTeacher"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="bottom|start"
            android:layout_marginBottom="170dp"
            android:layout_marginStart="10dp"
            android:elevation="110dp" />

        <LinearLayout
            android:id="@+id/tutorialDialogBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_margin="20dp"
            android:background="@drawable/macroflow_dialog_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:elevation="105dp">

            <TextView
                android:id="@+id/tutorialSpeakerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SNORLAX"
                android:textColor="@color/brand_accent_deep"
                android:fontFamily="sans-serif-black"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tutorialText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="..."
                android:textColor="@color/brand_dark"
                android:textSize="17sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>