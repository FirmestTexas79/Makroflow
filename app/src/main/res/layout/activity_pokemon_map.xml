<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mapRootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <RelativeLayout
        android:id="@+id/mapMainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Mapa, fitXY = přesně na rozměry view -->
        <ImageView
            android:id="@+id/mapBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            android:src="@drawable/poketown" />

        <!--
            HOTSPOTY — elevation 25dp (vyšší než fragment container 20dp).
            Díky tomu dostávají touch eventy i když je nad mapou prázdný container.
            Jakmile je fragment otevřen, Activity hotspoty programově zakáže
            (setClickable(false)) a opět povolí při zavření.
        -->
        <View
            android:id="@+id/hotspotForest"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_alignParentTop="true"
            android:background="@android:color/transparent"
            android:elevation="25dp" />

        <View
            android:id="@+id/hotspotHome"
            android:layout_width="130dp"
            android:layout_height="110dp"
            android:layout_alignParentStart="true"
            android:layout_marginTop="155dp"
            android:background="@android:color/transparent"
            android:elevation="25dp" />

        <View
            android:id="@+id/hotspotPokedex"
            android:layout_width="130dp"
            android:layout_height="110dp"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="155dp"
            android:background="@android:color/transparent"
            android:elevation="25dp" />

        <View
            android:id="@+id/hotspotShop"
            android:layout_width="180dp"
            android:layout_height="130dp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="280dp"
            android:background="@android:color/transparent"
            android:elevation="25dp" />

        <!-- Ash sprite -->
        <ImageView
            android:id="@+id/ashView"
            android:layout_width="28dp"
            android:layout_height="42dp"
            android:scaleType="fitCenter"
            android:elevation="10dp" />

        <!-- Companion — vlevo nahoře -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_marginTop="60dp"
            android:layout_marginStart="16dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:elevation="15dp">

            <TextView
                android:id="@+id/tvCompanionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FEFAE0"
                android:textSize="18sp"
                android:textAllCaps="true"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:shadowColor="#000000"
                android:shadowDx="3"
                android:shadowDy="3"
                android:shadowRadius="3"
                android:visibility="gone" />

            <FrameLayout
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginTop="4dp">

                <View
                    android:id="@+id/companionShadow"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_status_pill"
                    android:backgroundTint="#606C38"
                    android:alpha="0.45"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/ivCompanion"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>

        <!-- Tlačítka vpravo nahoře -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="60dp"
            android:layout_marginEnd="16dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:elevation="15dp">

            <ImageButton
                android:id="@+id/btnExitMap"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_status_pill"
                android:backgroundTint="#283618"
                android:padding="12dp"
                android:scaleType="fitCenter"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#FEFAE0"
                android:elevation="4dp" />

            <ImageButton
                android:id="@+id/btnStartTutorial"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_status_pill"
                android:backgroundTint="#606C38"
                android:padding="12dp"
                android:scaleType="fitCenter"
                android:src="@android:drawable/ic_menu_help"
                app:tint="#FEFAE0"
                android:elevation="4dp" />
        </LinearLayout>

        <!--
            Fragment container — elevation 20dp.
            Vizuálně překryje Ashe (10dp), tlačítka (15dp) i companion (15dp)
            jakmile je fragment otevřen.
            Hotspoty (25dp) jsou sice výše v touch hierarchii, ale Activity
            je deaktivuje (isClickable = false) dokud je fragment otevřen.
        -->
        <FrameLayout
            android:id="@+id/mapFragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:elevation="20dp" />

    </RelativeLayout>

    <!-- Tutorial overlay — nejvýše ze všeho -->
    <FrameLayout
        android:id="@+id/tutorialOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:elevation="100dp">

        <ImageView
            android:id="@+id/tutorialTeacher"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="bottom|start"
            android:layout_marginBottom="150dp"
            android:layout_marginStart="10dp"
            android:elevation="110dp" />

        <LinearLayout
            android:id="@+id/tutorialDialogBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_margin="20dp"
            android:background="@drawable/macroflow_dialog_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:elevation="105dp">

            <TextView
                android:id="@+id/tutorialSpeakerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SNORLAX"
                android:textColor="@color/brand_accent_deep"
                android:fontFamily="sans-serif-black"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tutorialText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="..."
                android:textColor="@color/brand_dark"
                android:textSize="17sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>